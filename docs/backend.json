
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the SquadForge application, storing personal and contact information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for login and communication.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's cell phone number (optional)."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image (optional).",
          "format": "uri"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Indicates if the user has globally enabled push notifications."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "isDemo": {
          "type": "boolean",
          "description": "Flag indicating if this is a demo admin account."
        },
        "activePlanId": {
          "type": "string",
          "description": "The ID of the plan currently active for the user's account."
        },
        "planSource": {
          "type": "string",
          "enum": [
            "free",
            "revenuecat",
            "manual"
          ],
          "description": "The source of the active subscription state."
        },
        "proTeamLimit": {
          "type": "number",
          "description": "The maximum number of teams this user can assign Pro features to."
        },
        "tournamentCredits": {
          "type": "number",
          "description": "Number of Elite Tournament module credits remaining."
        },
        "revenueCatUserId": {
          "type": "string",
          "description": "The unique identifier for this user in RevenueCat."
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "notificationsEnabled",
        "createdAt"
      ]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team or group within the application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "teamName": {
          "type": "string"
        },
        "sport": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "teamLogoUrl": {
          "type": "string",
          "format": "uri"
        },
        "teamCode": {
          "type": "string"
        },
        "ownerUserId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "planId": {
          "type": "string"
        },
        "isPro": {
          "type": "boolean"
        },
        "leagueIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "id",
        "teamName",
        "teamCode",
        "ownerUserId"
      ]
    },
    "League": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "League",
      "type": "object",
      "description": "A competitive grouping of multiple teams.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", format: "date-time" },
        "sport": { "type": "string" },
        "teams": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "teamName": { "type": "string" },
              "teamLogoUrl": { "type": "string" },
              "wins": { "type": "number" },
              "losses": { "type": "number" },
              "ties": { "type": "number" },
              "points": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "name", "creatorId"]
    },
    "LeagueRegistration": {
      "title": "LeagueRegistration",
      "type": "object",
      "properties": {
        "league_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "payment_instructions": { "type": "string" },
        "is_active": { "type": "boolean" },
        "shareable_slug": { "type": "string" },
        "created_by": { "type": "string" }
      }
    },
    "RegistrationForm": {
      "title": "RegistrationForm",
      "type": "object",
      "properties": {
        "league_registration_id": { "type": "string" },
        "version": { "type": "number" },
        "schema_json": { "type": "string" },
        "is_active": { "type": "boolean" }
      }
    },
    "RegistrationEntry": {
      "title": "RegistrationEntry",
      "type": "object",
      "properties": {
        "league_registration_id": { "type": "string" },
        "form_version": { "type": "number" },
        "answers_json": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "assigned", "declined"] },
        "assigned_team_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "TeamEvent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TeamEvent",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teamId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "endDate": { "type": "string" },
        "isTournament": { "type": "boolean" },
        "tournamentGames": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "team1": { "type": "string" },
              "team2": { "type": "string" },
              "score1": { "type": "number" },
              "score2": { "type": "number" },
              "date": { "type": "string" },
              "time": { "type": "string" },
              "winnerId": { "type": "string" }
            }
          }
        },
        "lastUpdated": { "type": "string" }
      }
    },
    "Subscription": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Subscription",
      "type": "object",
      "description": "User-level subscription state synced from RevenueCat or set manually.",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The active product identifier."
        },
        "entitlementActive": {
          "type": "boolean",
          "description": "Whether the Pro entitlement is currently active."
        },
        "proTeamLimit": {
          "type": "number",
          "description": "Number of Pro teams allowed by this subscription."
        },
        "source": {
          "type": "string",
          "enum": [
            "revenuecat",
            "manual"
          ],
          "description": "The authoritative source of this subscription state."
        },
        "lastSyncedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this state was last refreshed from the provider."
        }
      },
      "required": [
        "productId",
        "entitlementActive",
        "proTeamLimit",
        "source",
        "lastSyncedAt"
      ]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/plans/{planId}": {
      "schema": {
        "$ref": "#/backend/entities/Plan"
      },
      "description": "Global collection defining subscription tiers."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/User"
      },
      "description": "Private user profiles."
    },
    "/teams/{teamId}": {
      "schema": {
        "$ref": "#/backend/entities/Team"
      },
      "description": "Collaborative team hubs."
    },
    "/teams/{teamId}/events/{eventId}": {
      "schema": {
        "$ref": "#/backend/entities/TeamEvent"
      },
      "description": "Team schedule and tournament data."
    },
    "/leagues/{leagueId}": {
      "schema": {
        "$ref": "#/backend/entities/League"
      },
      "description": "Competitive league hubs."
    },
    "/leagues/{leagueId}/registration": {
      "schema": {
        "$ref": "#/backend/entities/LeagueRegistration"
      },
      "description": "League-wide signup configuration."
    },
    "/leagues/{leagueId}/registrationEntries/{entryId}": {
      "schema": {
        "$ref": "#/backend/entities/RegistrationEntry"
      },
      "description": "Submitted signups for the league."
    }
  }
}

    