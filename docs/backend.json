
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the SquadForge application, storing personal and contact information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address, used for login and communication.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's cell phone number (optional)."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image (optional).",
          "format": "uri"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Indicates if the user has globally enabled push notifications."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        },
        "isDemo": {
          "type": "boolean",
          "description": "Flag indicating if this is a demo admin account."
        },
        "activePlanId": {
          "type": "string",
          "description": "The ID of the plan currently active for the user's account."
        },
        "planSource": {
          "type": "string",
          "enum": [
            "free",
            "revenuecat",
            "manual"
          ],
          "description": "The source of the active subscription state."
        },
        "proTeamLimit": {
          "type": "number",
          "description": "The maximum number of teams this user can assign Pro features to."
        },
        "tournamentCredits": {
          "type": "number",
          "description": "Number of Elite Tournament module credits remaining."
        },
        "revenueCatUserId": {
          "type": "string",
          "description": "The unique identifier for this user in RevenueCat."
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "notificationsEnabled",
        "createdAt"
      ]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team or group within the application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "teamName": {
          "type": "string"
        },
        "sport": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "teamLogoUrl": {
          "type": "string",
          "format": "uri"
        },
        "teamCode": {
          "type": "string"
        },
        "ownerUserId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "planId": {
          "type": "string"
        },
        "isPro": {
          "type": "boolean"
        },
        "leagueIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "id",
        "teamName",
        "teamCode",
        "ownerUserId"
      ]
    },
    "VolunteerOpportunity": {
      "title": "VolunteerOpportunity",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "slots": { "type": "number" },
        "hoursPerSlot": { "type": "number" },
        "signups": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "status": { "type": "string", "enum": ["signed_up", "completed", "verified"] },
              "verifiedHours": { "type": "number" }
            }
          }
        }
      }
    },
    "FundraisingOpportunity": {
      "title": "FundraisingOpportunity",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goalAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "participants": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" }
            }
          }
        }
      }
    },
    "EquipmentItem": {
      "title": "EquipmentItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "totalQuantity": { "type": "number" },
        "availableQuantity": { "type": "number" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Maintenance", "Retired"] },
        "assignments": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "userName": { "type": "string" },
              "quantity": { "type": "number" },
              "assignedAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    },
    "ScoutingReport": {
      "title": "ScoutingReport",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "opponentName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "strengths": { "type": "string" },
        "weaknesses": { "type": "string" },
        "keysToVictory": { "type": "string" },
        "videoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StaffEvaluation": {
      "title": "StaffEvaluation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/User"
      },
      "description": "Private user profiles."
    },
    "/teams/{teamId}": {
      "schema": {
        "$ref": "#/backend/entities/Team"
      },
      "description": "Collaborative team hubs."
    },
    "/teams/{teamId}/volunteers/{oppId}": {
      "schema": {
        "$ref": "#/backend/entities/VolunteerOpportunity"
      },
      "description": "Parent volunteer signups and hour tracking."
    },
    "/teams/{teamId}/fundraising/{fundId}": {
      "schema": {
        "$ref": "#/backend/entities/FundraisingOpportunity"
      },
      "description": "Squad fundraising campaigns."
    },
    "/teams/{teamId}/equipment/{itemId}": {
      "schema": {
        "$ref": "#/backend/entities/EquipmentItem"
      },
      "description": "Team inventory and equipment tracking."
    },
    "/teams/{teamId}/scouting/{reportId}": {
      "schema": {
        "$ref": "#/backend/entities/ScoutingReport"
      },
      "description": "Opponent analysis and tactical scouting."
    },
    "/teams/{teamId}/members/{memberId}/evaluations/notes": {
      "schema": {
        "$ref": "#/backend/entities/StaffEvaluation"
      },
      "description": "Private staff notes and evaluations for team members."
    }
  }
}
