
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the application, managing personal details and global notification preferences.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "notificationsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "activePlanId": { "type": "string" },
        "proTeamLimit": { "type": "number" }
      },
      "required": ["id", "fullName", "email", "notificationsEnabled", "createdAt"]
    },
    "PlayerProfile": {
      "title": "PlayerProfile",
      "type": "object",
      "description": "Base player data, now extended with recruiting status.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "recruitingProfileEnabled": { "type": "boolean" },
        "photoURL": { "type": "string" }
      }
    },
    "RecruitingProfile": {
      "title": "RecruitingProfile",
      "type": "object",
      "properties": {
        "status": { "type": "string", "enum": ["active", "hidden", "committed"] },
        "primaryPosition": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "academicGPA": { "type": "number" },
        "graduationYear": { "type": "number" },
        "bio": { "type": "string" },
        "highlightVideo": { "type": "string" }
      }
    },
    "AthleticMetrics": {
      "title": "AthleticMetrics",
      "type": "object",
      "properties": {
        "fortyYardDash": { "type": "number" },
        "verticalJump": { "type": "number" },
        "benchPress": { "type": "number" },
        "verified": { "type": "boolean" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "description": "User profiles." }
      },
      {
        "path": "/players/{playerId}",
        "definition": { "entityName": "PlayerProfile", "description": "Athletes (Adult or Minor)." }
      },
      {
        "path": "/players/{playerId}/recruitingProfile/profile",
        "definition": { "entityName": "RecruitingProfile", "description": "Detailed recruiting metadata." }
      },
      {
        "path": "/players/{playerId}/recruitingProfile/metrics",
        "definition": { "entityName": "AthleticMetrics", "description": "Physical performance data." }
      },
      {
        "path": "/players/{playerId}/recruitingProfile/stats",
        "definition": { "entityName": "Object", "description": "Seasonal statistics." }
      },
      {
        "path": "/players/{playerId}/evaluations/{evalId}",
        "definition": { "entityName": "Object", "description": "Coach/Scout ratings." }
      },
      {
        "path": "/players/{playerId}/videos/{videoId}",
        "definition": { "entityName": "Object", "description": "Recruiting film hub." }
      }
    ]
  }
}
