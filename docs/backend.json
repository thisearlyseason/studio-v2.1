
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the application, managing personal details and global notification preferences.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "avatarUrl": { "type": "string", "format": "uri" },
        "notificationsEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "activePlanId": { "type": "string" },
        "proTeamLimit": { "type": "number" }
      },
      "required": ["id", "fullName", "email", "notificationsEnabled", "createdAt"]
    },
    "Household": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Household",
      "type": "object",
      "description": "Represents a family unit, linking parents/guardians to multiple minor players for unified management.",
      "properties": {
        "id": { "type": "string" },
        "parentIds": { "type": "array", "items": { "type": "string" } },
        "playerIds": { "type": "array", "items": { "type": "string" } },
        "billingEmail": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "parentIds", "playerIds", "createdAt"]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team that users can create, join, and manage.",
      "properties": {
        "id": { "type": "string" },
        "teamName": { "type": "string" },
        "sport": { "type": "string" },
        "teamLogoUrl": { "type": "string", "format": "uri" },
        "teamCode": { "type": "string" },
        "planId": { "type": "string" },
        "isPro": { "type": "boolean" },
        "ownerUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "teamName", "teamCode", "createdAt"]
    },
    "Facility": {
      "title": "Facility",
      "type": "object",
      "description": "An athletic venue with multiple fields or courts.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "clubId": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "League": {
      "title": "League",
      "type": "object",
      "description": "A competitive organization hosting multiple teams.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creatorId": { "type": "string" },
        "teams": { "type": "object" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": { "entityName": "UserProfile", "description": "User profiles." }
      },
      {
        "path": "/households/{householdId}",
        "definition": { "entityName": "Household", "description": "Guardian family units." }
      },
      {
        "path": "/players/{playerId}",
        "definition": { "entityName": "PlayerProfile", "description": "Athletes (Adult or Minor)." }
      },
      {
        "path": "/teams/{teamId}",
        "definition": { "entityName": "Team", "description": "Squad data hub." }
      },
      {
        "path": "/teams/{teamId}/documents/{docId}/signatures/{sigId}",
        "definition": { "entityName": "DocumentSignature", "description": "Verified legal signatures." }
      },
      {
        "path": "/facilities/{facilityId}",
        "definition": { "entityName": "Facility", "description": "Venue management." }
      },
      {
        "path": "/leagues/{leagueId}",
        "definition": { "entityName": "League", "description": "Competitive hubs." }
      }
    ]
  }
}
