
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information within the SquadForge application, used for identification and personalization.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The user's phone number."
        },
        "avatarUrl": {
          "type": "string",
          "description": "URL to the user's profile avatar image.",
          "format": "uri"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Indicates if the user has globally enabled push notifications."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the user account was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "fullName",
        "email",
        "notificationsEnabled",
        "createdAt"
      ]
    },
    "Team": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Team",
      "type": "object",
      "description": "Represents a sports team within the SquadForge application, enabling collaboration and event management.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Team entity."
        },
        "teamName": {
          "type": "string",
          "description": "The name of the team."
        },
        "sport": {
          "type": "string",
          "description": "The sport the team plays."
        },
        "teamLogoUrl": {
          "type": "string",
          "description": "URL to the team's logo image.",
          "format": "uri"
        },
        "teamCode": {
          "type": "string",
          "description": "A unique 6-character alphanumeric code used for joining the team."
        },
        "createdBy": {
          "type": "string",
          "description": "Reference to the UserProfile who created this team. (Relationship: UserProfile 1:N Team)"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp when the team was created.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "teamName",
        "teamCode",
        "createdBy",
        "createdAt"
      ]
    },
    "League": {
      "title": "League",
      "type": "object",
      "description": "A competitive league hierarchy containing multiple teams, standings, and registration protocols.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sport": { "type": "string" },
        "memberTeamIds": { "type": "array", "items": { "type": "string" } },
        "inviteCode": { "type": "string" },
        "creatorId": { "type": "string" }
      }
    },
    "RegistrationEntry": {
      "title": "RegistrationEntry",
      "type": "object",
      "description": "An applicant's enrollment data for a league or squad.",
      "properties": {
        "id": { "type": "string" },
        "league_id": { "type": "string" },
        "answers": { "type": "object" },
        "status": { "type": "string", "enum": ["pending", "assigned", "accepted", "declined"] }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/leagues/{leagueId}",
        "definition": {
          "entityName": "League",
          "schema": { "$ref": "#/backend/entities/League" },
          "description": "Top-level competitive league data."
        }
      },
      {
        "path": "/leagues/{leagueId}/registrationEntries/{entryId}",
        "definition": {
          "entityName": "RegistrationEntry",
          "schema": { "$ref": "#/backend/entities/RegistrationEntry" },
          "description": "Recruitment pool applications for a league."
        }
      },
      {
        "path": "/leagues/global/invites/{inviteId}",
        "definition": {
          "entityName": "LeagueInvite",
          "schema": { "type": "object" },
          "description": "Global recruitment invitations."
        }
      }
    ]
  }
}
