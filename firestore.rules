rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      // Robust check for authentication token presence
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- LEAGUES & REGISTRATION SECTOR ---
    
    match /leagues/{leagueId} {
      // Allow reading the league document itself for valid codes/discovery
      allow get: if isSignedIn();
      // Allow listing if signed in (provable path)
      allow list: if isSignedIn();
      allow write: if isSignedIn();

      match /registrationEntries/{entryId} {
        allow read, write: if isSignedIn();
      }
      
      match /registration/{configId} {
        allow read, write: if isSignedIn();
      }
      
      match /payments/{paymentId} {
        allow read, write: if isSignedIn();
      }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- TEAMS & COORDINATION SECTOR ---

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      // Explicit matches for nested coordination data to satisfy List Proving
      match /members/{memberId} { allow read, write: if isSignedIn(); }
      match /events/{eventId} { allow read, write: if isSignedIn(); }
      match /feedPosts/{postId} { allow read, write: if isSignedIn(); }
      match /groupChats/{chatId} { allow read, write: if isSignedIn(); }
      match /equipment/{itemId} { allow read, write: if isSignedIn(); }
      match /incidents/{incidentId} { allow read, write: if isSignedIn(); }
      match /volunteers/{oppId} { allow read, write: if isSignedIn(); }
      match /fundraising/{fundId} { allow read, write: if isSignedIn(); }
      match /drills/{drillId} { allow read, write: if isSignedIn(); }
      match /files/{fileId} { allow read, write: if isSignedIn(); }
      match /games/{gameId} { allow read, write: if isSignedIn(); }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONAL & PROFILE INFRASTRUCTURE ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
      
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Legacy mapping support
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL REPOSITORIES ---

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans/{planId} { allow read: if true; }
    match /features/{featureId} { allow read: if true; }
    
    match /team_memberships/{id} { allow read, write: if isSignedIn(); }
    match /subscriptions/{id} { allow read, write: if isSignedIn(); }

    // --- COLLECTION GROUP ACCESS (CRITICAL FOR HUBS) ---
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}