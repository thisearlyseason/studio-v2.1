rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Super admin: verified server-side via Firebase Custom Claims.
    // Set with: admin.auth().setCustomUserClaims(uid, { role: 'superadmin' })
    // This cannot be forged by clients — it's signed into the JWT by Firebase.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'superadmin';
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    function isTeamOwner(teamId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSuperAdmin() || (isSignedIn() && isOwner(userId));
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSuperAdmin() || (isSignedIn() && isOwner(userId));
      allow delete: if false; // Never allow client-side user deletion

      // Google OAuth tokens — server-write only via Cloud Functions
      match /tokens/{tokenId} {
        allow read, write: if false;
      }

      // Team membership index — readable by owner
      match /teamMemberships/{teamId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow write: if isSignedIn() && isOwner(userId);
      }
    }

    // ─── Teams ──────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Owner, any authenticated member, or super admin can read team doc
      allow read: if isSuperAdmin() || (isSignedIn() && (
        resource.data.ownerUserId == request.auth.uid ||
        isTeamMember(teamId)
      ));
      allow create: if isSignedIn() && request.resource.data.ownerUserId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && (
        resource.data.ownerUserId == request.auth.uid ||
        isTeamMember(teamId)
      ));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.ownerUserId == request.auth.uid);

      // Sub-collections: only members can read; only owner can write
      match /members/{memberId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (
          resource.data.ownerUserId == request.auth.uid ||
          isTeamMember(teamId)
        ));
        allow write: if isSuperAdmin() || (isSignedIn() && isTeamOwner(teamId));
      }

      match /events/{eventId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && isTeamOwner(teamId));
      }

      match /incidents/{incidentId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && isTeamOwner(teamId));
      }

      match /games/{gameId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && isTeamOwner(teamId));
      }

      match /fundraising/{fundId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));

        match /donations/{donationId} {
          allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
          allow write: if isSuperAdmin() || isSignedIn();
        }
      }

      // Catch-all for any other team sub-collections
      match /{subCollection}/{docId} {
        allow read, write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
      }
    }

    // ─── Players (public scouting profiles) ─────────────────────────────────
    match /players/{playerId} {
      // Public read for recruiting portals (coaches, scouts, parents)
      allow read: if true;
      // Create: must be signed in and set userId to their own UID (prevents impersonation)
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Update/delete: only the profile owner or a superadmin
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /{subCollection}/{docId} {
        allow read: if true;
        // Sub-collection writes: only owner or superadmin
        allow write: if isSuperAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/players/$(playerId)).data.userId == request.auth.uid);
      }
    }

    // ─── Leagues ────────────────────────────────────────────────────────────
    match /leagues/{leagueId} {
      // Anyone signed in can read league docs (for registration/standings)
      allow read: if isSignedIn();
      // Only the creator can write league config
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      match /registrationEntries/{entryId} {
        // Public write to allow team/player registration from public form
        allow create: if true;
        // Only league owner can read/update entries
        allow read, update: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
        allow delete: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
      }

      match /archived_waivers/{waiverId} {
        allow read, write: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
      }

      match /registration/{configId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
      }

      match /scores/{scoreId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Global invites collection
      match /invites/{inviteId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── Leagues global invites ──────────────────────────────────────────────
    match /leagues/global/invites/{inviteId} {
      allow read, write: if isSignedIn();
    }

    // ─── Plans (pricing/feature tiers) ──────────────────────────────────────
    // Public read: pricing page and unauthenticated visitors need plan metadata.
    // Write is superadmin-only — plan definitions are managed via the admin portal or scripts.
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── Subscriptions audit log (server-write only via webhook) ────────────
    match /subscriptions/{subId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Server-side only
    }

    // ─── Calendar feeds (token-gated) ───────────────────────────────────────
    match /calendarFeeds/{feedId} {
      allow read: if true; // Token is the secret — anyone with the token URL can read
      allow write: if isSignedIn();
    }

    // ─── Volunteers ─────────────────────────────────────────────────────────
    match /volunteerOpportunities/{oppId} {
      allow read: if true; // Public volunteer listings
      allow write: if isSignedIn();

      match /signups/{signupId} {
        allow read: if true;
        allow write: if true; // Public sign-up flow
      }
    }

    // ─── Signatures (global top-level — distinct from team sub-collection) ────
    match /signatures/{sigId} {
      // Owners can read their own; superadmins can read any
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Only the signer themselves can write — userId field must match auth uid
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // ─── Alerts ─────────────────────────────────────────────────────────────
    match /alerts/{alertId} {
      // All signed-in users can read alerts for their teams (client-side filters by teamId)
      allow read: if isSignedIn();
      // Write: only superadmin or team owner/member (teamId field must match a team they belong to)
      // This prevents arbitrary alert injection from any signed-in account.
      allow create: if isSuperAdmin() || (
        isSignedIn() && (
          request.resource.data.createdBy == request.auth.uid &&
          (
            request.resource.data.teamId == null ||
            isTeamMember(request.resource.data.teamId) ||
            isTeamOwner(request.resource.data.teamId)
          )
        )
      );
      allow update, delete: if isSuperAdmin() || (
        isSignedIn() && resource.data.createdBy == request.auth.uid
      );
    }
  }
}