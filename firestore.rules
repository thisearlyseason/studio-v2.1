rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      // Safe check for email to handle anonymous/demo users where email is null
      return isSignedIn() && 
        (request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
         request.auth.token.get('email', '') == 'test@gmail.com');
    }

    function isDemoTeam(teamId) {
      return teamId.startsWith('demo_');
    }

    function isAdmin(teamId) {
      // Prioritize demo check to avoid get() failures during batch initialization
      return isSignedIn() && (
        isSuperAdmin() ||
        isDemoTeam(teamId) ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
          (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.get('role', '') == 'Admin')
        ))
      );
    }

    // Collection Group Queries - Recruitment Ledger
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn() && (
        resource.data.get('assigned_team_owner_id', '') == request.auth.uid || 
        isSuperAdmin() ||
        resource.data.get('assigned_team_id', '').startsWith('demo_')
      );
      allow update: if isSignedIn() && (
        resource.data.get('assigned_team_owner_id', '') == request.auth.uid ||
        isSuperAdmin() ||
        resource.data.get('assigned_team_id', '').startsWith('demo_')
      );
      allow delete: if isSuperAdmin();
    }

    // Legally Safe Collections for Minors
    match /players/{playerId} {
      allow read: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    match /families/{familyId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.parentId == request.auth.uid || isSuperAdmin()
      );
    }

    match /waivers/{waiverId} {
      allow read: if isSignedIn() && (
        resource.data.signedByUserId == request.auth.uid || isSuperAdmin()
      );
      allow create: if isSignedIn() && (
        (request.resource.data.signedByRole == 'player' && request.resource.data.signedByUserId == request.auth.uid) ||
        (request.resource.data.signedByRole == 'parent' && request.resource.data.signedByUserId == request.auth.uid)
      );
    }

    // Existing Collections
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(teamId) || isDemoTeam(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isOwner(memberId) || isDemoTeam(teamId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isDemoTeam(teamId);
        
        match /registrations/{regId} {
          allow read, write: if isSignedIn();
        }
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, update: if isAdmin(teamId) || isDemoTeam(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isDemoTeam(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isDemoTeam(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isDemoTeam(teamId);
        
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isAdmin(teamId) || resource.data.authorId == request.auth.uid || isDemoTeam(teamId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds || isDemoTeam(teamId));
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (request.auth.uid in resource.data.memberIds || isDemoTeam(teamId));
        
        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isDemoTeam(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isSuperAdmin());
      
      match /registration/{config} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid);
      }

      match /registrationEntries/{entryId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid ||
          resource.data.get('assigned_team_owner_id', '') == request.auth.uid
        );
        allow create: if true; // Public signups
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid ||
          resource.data.get('assigned_team_owner_id', '') == request.auth.uid
        );
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid);
      }

      match /invites/{inviteId} {
        allow read: if isSignedIn() && (
          resource.data.get('invitedEmail', '').lower() == request.auth.token.get('email', '').lower() ||
          (resource.data.get('invitedEmail', '').lower().startsWith('guest@') && isSignedIn()) ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid ||
          isSuperAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          resource.data.get('invitedEmail', '').lower() == request.auth.token.get('email', '').lower() ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid
        );
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }
  }
}