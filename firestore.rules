rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/team_memberships/$(teamId + "_" + request.auth.uid))
      );
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'Admin' ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid
      );
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Players ---
    match /players/{playerId} {
      allow read: if isSignedIn();
      // Allow creation for self-registration or parent adding child
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == resource.data.parentId || request.auth.uid == resource.data.userId);
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      // Allow creation for new coaches/managers
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      // Recursive wildcard for subcollections (members, events, chats, etc.)
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId);
      }
    }

    // --- Team Memberships (Global index for user queries) ---
    match /team_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Facilities ---
    match /facilities/{facId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Leagues ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.creatorId;
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
    }
    match /features/{featureId} {
      allow read: if true;
    }

    // --- Collection Groups (For multi-squad views) ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    // Deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}