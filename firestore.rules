rules_version = '2';

/**
 * SquadForge Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a hybrid security model combining strict User Ownership and 
 * Denormalized Shared Access. The goal is to provide high security with maximum performance 
 * by avoiding costly cross-document lookups (get() calls) during authorization.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isTeamMember(data) {
      return isSignedIn() && (
        data.teamMembers[request.auth.uid] != null || 
        data.members[request.auth.uid] != null
      );
    }

    function isTeamAdmin(data) {
      return isSignedIn() && (
        data.teamMembers[request.auth.uid] == 'admin' || 
        data.members[request.auth.uid] == 'admin'
      );
    }

    // --- COLLECTION RULES ---

    /**
     * @description Enforces strict ownership over the user's root profile.
     * Explicitly allows demo/custom auth users who have a UID but potentially no email.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /**
     * @description Global metadata for application initialization.
     */
    match /plans/{planId} {
      allow read: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if isSignedIn();
    }

    /**
     * @description Manages top-level Team documents.
     */
    match /teams/{teamId} {
      allow get, list: if isSignedIn() && (resource.data.members[request.auth.uid] != null || resource.data.ownerUserId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.members[request.auth.uid] == 'admin' || resource.data.ownerUserId == request.auth.uid);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /feedPosts/{postId} {
        allow read, list: if isTeamMember(resource.data);
        allow create: if isTeamMember(request.resource.data) && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isExistingOwner(resource.data.authorId) || isTeamAdmin(resource.data);

        match /comments/{commentId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isExistingOwner(resource.data.authorId);
        }
      }

      match /events/{eventId} {
        allow read, list: if isTeamMember(resource.data);
        allow create: if isTeamAdmin(request.resource.data);
        allow update, delete: if isTeamAdmin(resource.data);

        match /registrations/{regId} {
          allow read, write: if isSignedIn();
        }
      }

      match /groupChats/{chatId} {
        allow read, list: if isTeamMember(resource.data) && request.auth.uid in resource.data.memberIds;
        allow create: if isTeamAdmin(request.resource.data);
        allow update, delete: if isTeamAdmin(resource.data);

        match /messages/{messageId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isExistingOwner(resource.data.authorId);
        }
      }

      match /files/{fileId} {
        allow read, list: if isTeamMember(resource.data);
        allow create: if isTeamMember(request.resource.data);
        allow update, delete: if isExistingOwner(resource.data.uploadedBy);
      }

      match /alerts/{alertId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // --- COLLECTION GROUP RULES (For aggregated views) ---

    match /{path=**}/events/{eventId} {
      allow read, list: if isTeamMember(resource.data);
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read, list: if isSignedIn();
    }
  }
}
