rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      // Robust check for anonymous/custom provider status used in development/demos
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom' ||
        request.auth.token.firebase.sign_in_provider == 'none'
      );
    }

    // --- Institutional Hierarchy: Leagues ---
    // Explicit matching for subcollections ensures LIST operations prove successful
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicitly authorize LIST and document access for invites
      match /invites {
        allow list: if isSignedIn();
      }
      match /invites/{inviteId} {
        allow get, create, update, delete: if isSignedIn();
      }
      
      // Explicitly authorize registration and entries
      match /registration {
        allow list: if isSignedIn();
      }
      match /registration/{configId} {
        allow read, write: if isSignedIn();
      }

      match /registrationEntries {
        allow list: if isSignedIn();
      }
      match /registrationEntries/{entryId} {
        allow read, write: if isSignedIn();
      }

      match /payments/{paymentId} {
        allow read, write: if isSignedIn();
      }
    }

    // Explicit matching for global league state (common in recruitment hub)
    // Authorizes paths like /leagues/global/invites
    match /leagues/global/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // --- Tactical Hierarchy: Teams ---
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      // Recursive wildcard ensures members can access chat, files, events, and rosters
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Personal Infrastructure: User Profiles ---
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Global Athlete Repository ---
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Physical Infrastructure: Facilities ---
    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Economy: Billing Plans ---
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAnonymous() || isSignedIn();
    }

    // --- Global Sentinels ---
    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- Cross-Squad Aggregation (Collection Groups) ---
    // Required for Master Calendar and Household Hub queries
    match /{path=**}/events/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/incidents/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/feedPosts/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/games/{id} {
      allow read, write: if isSignedIn();
    }

    // --- Global Default Deny ---
    // Prevents unauthorized root-level scans
    match /{path=**} {
      allow read, write: if false;
    }
  }
}