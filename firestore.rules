rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' ||
        request.auth.token.email == 'test@gmail.com'
      );
    }

    function isTeamStaff(teamId) {
      if (!isSignedIn()) return false;
      if (teamId.matches('^demo_.*')) return true;
      if (isSuperAdmin()) return true;
      
      let teamPath = /databases/$(database)/documents/teams/$(teamId);
      let memberPath = /databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid);
      
      return (exists(teamPath) && get(teamPath).data.ownerUserId == request.auth.uid) ||
             (exists(memberPath) && get(memberPath).data.role == 'Admin') ||
             (exists(memberPath) && get(memberPath).data.position in ['Coach', 'Assistant Coach', 'Manager', 'Team Representative']);
    }

    function isTeamMember(teamId) {
      if (!isSignedIn()) return false;
      if (teamId.matches('^demo_.*')) return true;
      if (isTeamStaff(teamId)) return true;
      
      let memberPath = /databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid);
      return exists(memberPath);
    }

    // --- COLLECTION RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isSignedIn(); 
      }
    }

    match /players/{playerId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      
      match /recruitingProfile/{docId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /evaluations/{evalId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /videos/{videoId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /teams/{teamId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isTeamStaff(teamId);

      match /members/{memberId} {
        allow read: if true; 
        allow write: if isTeamStaff(teamId) || isOwner(memberId) || teamId.matches('^demo_.*');
        
        match /signatures/{sigId} {
          allow read: if true;
          allow write: if true;
        }
      }

      match /documents/{docId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
      }

      match /events/{eventId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
      }

      match /volunteers/{oppId} {
        allow read: if true;
        allow write: if true; 
      }

      match /fundraising/{fundId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
        
        match /donations/{donationId} {
          allow read: if true;
          allow create: if true; 
          allow update: if isTeamStaff(teamId);
        }
      }

      match /feedPosts/{postId} {
        allow read: if true;
        allow create: if isTeamStaff(teamId);
        allow update, delete: if isTeamStaff(teamId);
        
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow delete: if isTeamStaff(teamId) || isOwner(request.auth.uid);
        }
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamStaff(teamId);
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamStaff(teamId);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamStaff(teamId);
      }

      match /groupChats/{chatId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamMember(teamId);

        match /messages/{msgId} {
          allow read, create: if isTeamMember(teamId);
        }
      }

      match /files/{fileId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if isTeamStaff(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      
      match /registration/{docId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /registrationEntries/{entryId} {
        allow read: if true;
        allow create: if true; 
        allow update, delete: if isSignedIn();
      }
    }

    match /facilities/{facId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /fields/{fieldId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // Support for collectionGroup queries
    match /{path=**}/donations/{donationId} {
      allow read: if true;
    }
    match /{path=**}/members/{memberId} {
      allow read: if true;
    }
    match /{path=**}/files/{fileId} {
      allow read: if true;
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if true;
    }
  }
}