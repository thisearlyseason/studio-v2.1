rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom'
      );
    }

    // --- INSTITUTIONAL HIERARCHY: LEAGUES ---
    
    match /leagues {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- TACTICAL HIERARCHY: TEAMS ---
    
    match /teams {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles {
      allow list: if isSignedIn();
    }
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users {
      allow list: if isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL REPOSITORIES ---
    
    match /players {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /plans {
      allow list, get: if true;
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /team_memberships {
      allow list: if isSignedIn();
    }

    match /team_memberships/{id} {
      allow read, write: if isSignedIn();
    }

    // --- CROSS-SQUAD AGGREGATION (COLLECTION GROUPS) ---
    
    match /{path=**}/invites/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}