rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' || 
        request.auth.uid in [
          '3Dybqi6vkHNUQQM66jiEZWfmwsW2',
          'wnvOuvwmoUhS5U4kdaBrZz7tGbF3',
          'PtT54iDDtUML1wslbZzxjDgbrFp1',
          'zGh7D5JfrFOkxhVJr79gtbzHPVC3'
        ]
      );
    }

    // --- GLOBAL CATALOG ---
    // Public read enabled for immediate platform initialization
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /features/{featureId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- PROVABLE HIERARCHIES ---
    // Using flattened, recursive wildcard matches to satisfy "List Proving" requirements
    
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }
    
    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}