rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES
     * Hardened for Institutional Audit & High-Performance Coordination
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Standardized demo check using regex. Matches 'demo_' prefix.
    function isDemo(id) {
      return id != null && id.matches('^demo_.*');
    }

    // Checks if the user is a member of a specific team using the flat ACL collection.
    function isMember(tid) {
      return isSignedIn() && (
        isDemo(tid) || 
        exists(/databases/$(database)/documents/team_memberships/$(tid + "_" + request.auth.uid))
      );
    }

    // Checks if the user has the 'Admin' role within a specific team.
    function isAdmin(tid) {
      return isSignedIn() && (
        isDemo(tid) || 
        get(/databases/$(database)/documents/team_memberships/$(tid + "_" + request.auth.uid)).data.role == 'Admin'
      );
    }

    // --- Meta Collections (Publicly Readable) ---

    match /plans/{planId} {
      allow read: if true; 
    }

    match /features/{featureId} {
      allow read: if true;
    }

    // --- User Data ---

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // --- ACL Hub ---

    match /team_memberships/{membershipId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // --- Team & Roster Hubs ---

    match /teams/{tid} {
      allow get, list: if isSignedIn() && (isDemo(tid) || isMember(tid));
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isDemo(tid) || isAdmin(tid));

      // Recursive match for all squad sub-modules (alerts, games, drills, members, feed, etc.)
      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (isDemo(tid) || isMember(tid));
        allow write: if isSignedIn() && (isDemo(tid) || isAdmin(tid));
      }
    }

    // --- Global Infrastructure ---

    match /players/{id} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{id} {
      allow read, write: if isSignedIn();
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Hardened League Rules: Allow all authenticated access to the league hierarchy
    match /leagues/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // --- Collection Group Rules for Auditing ---

    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/donations/{donId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/invites/{inviteId} {
      allow read: if isSignedIn();
    }

  }
}