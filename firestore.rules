rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- LEAGUES & RECRUITMENT ---
    
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
    }

    match /leagues/{leagueId}/registrationEntries/{entryId} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registration/{configId} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    // --- TEAMS & COORDINATION ---

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/members/{memberId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/events/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/feedPosts/{postId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/feedPosts/{postId}/comments/{commentId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/groupChats/{chatId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/groupChats/{chatId}/messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/equipment/{itemId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/incidents/{incidentId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/volunteers/{oppId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/fundraising/{fundId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/fundraising/{fundId}/donations/{donId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/drills/{drillId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/files/{fileId} {
      allow read, write: if isSignedIn();
    }

    match /teams/{teamId}/games/{gameId} {
      allow read, write: if isSignedIn();
    }

    // --- PERSONNEL & PRIVATE DATA ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/teamMemberships/{membershipId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/hiddenChats/{chatId} {
      allow read, write: if isOwner(userId);
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
    }

    match /players/{playerId}/evaluations/{evalId} {
      allow read, write: if isSignedIn();
    }

    match /players/{playerId}/videos/{videoId} {
      allow read, write: if isSignedIn();
    }

    match /players/{playerId}/recruitingProfile/{docId} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{facilityId}/fields/{fieldId} {
      allow read, write: if isSignedIn();
    }

    match /plans/{planId} {
      allow read: if true;
    }

    match /features/{featureId} {
      allow read: if true;
    }

    // --- COLLECTION GROUP ACCESS ---
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}