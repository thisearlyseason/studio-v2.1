rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    
    // Leagues Hub - Explicit matching for List Proving
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicit subcollection matches to satisfy collection-level queries
      match /registrationEntries/{id} { allow read, write: if isSignedIn(); }
      match /registration/{id} { allow read, write: if isSignedIn(); }
      match /members/{id} { allow read, write: if isSignedIn(); }
      match /events/{id} { allow read, write: if isSignedIn(); }
      match /payments/{id} { allow read, write: if isSignedIn(); }
      
      // Recursive fallback for nested dynamic structures
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Teams Hub - Explicit matching for List Proving
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      match /members/{id} { allow read, write: if isSignedIn(); }
      match /events/{id} { allow read, write: if isSignedIn(); }
      match /feedPosts/{id} { allow read, write: if isSignedIn(); }
      match /groupChats/{id} { allow read, write: if isSignedIn(); }
      match /incidents/{id} { allow read, write: if isSignedIn(); }
      match /files/{id} { allow read, write: if isSignedIn(); }
      match /drills/{id} { allow read, write: if isSignedIn(); }
      match /equipment/{id} { allow read, write: if isSignedIn(); }
      match /volunteers/{id} { allow read, write: if isSignedIn(); }
      match /fundraising/{id} { allow read, write: if isSignedIn(); }
      match /documents/{id} { allow read, write: if isSignedIn(); }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      // Explicit match for memberships query
      match /teamMemberships/{id} { allow read, write: if isOwner(userId); }
      match /hiddenChats/{id} { allow read, write: if isOwner(userId); }
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL REPOSITORIES ---

    match /plans/{planId} { allow read: if true; allow write: if isSignedIn(); }
    match /features/{featureId} { allow read: if true; allow write: if isSignedIn(); }
    match /facilities/{facilityId} { 
      allow read, write: if isSignedIn(); 
      match /{allPaths=**} { allow read, write: if isSignedIn(); }
    }
    match /players/{playerId} { 
      allow read, write: if isSignedIn(); 
      match /{allPaths=**} { allow read, write: if isSignedIn(); }
    }
    match /team_memberships/{membershipId} { allow read, write: if isSignedIn(); }
    match /subscriptions/{subId} { allow read, write: if isSignedIn(); }

    // --- COLLECTION GROUPS ---
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}