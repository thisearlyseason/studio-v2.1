rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Top-level memberships collection used for ACL and Seeder
    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // Broad recursive rules for organizational units to ensure deep nested access
    match /teams/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /leagues/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /players/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Global Catalog Rules - Publicly readable for pricing/marketing
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Managed by backend webhooks
    }

    // --- Collection Group Rules for Auditing ---

    match /{path=**}/signatures/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/incidents/{incidentId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }

    // Catch-all default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}