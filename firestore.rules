rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' ||
        request.auth.token.email == 'test@gmail.com'
      );
    }

    function isTeamStaff(teamId) {
      let teamPath = /databases/$(database)/documents/teams/$(teamId);
      let memberPath = /databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid);
      
      return isSignedIn() && (
        isSuperAdmin() || 
        (exists(teamPath) && get(teamPath).data.ownerUserId == request.auth.uid) ||
        (exists(memberPath) && get(memberPath).data.position in ['Coach', 'Assistant Coach', 'Team Representative', 'Manager', 'Organization Lead', 'Platform Admin', 'Squad Leader', 'Parent'])
      );
    }

    function isRecruitingStaff(playerId) {
      return isSignedIn() && (isSuperAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)));
    }

    // --- COLLECTION RULES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isSignedIn(); 
      }
    }

    match /players/{playerId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      
      match /recruitingProfile/{docId} {
        allow read: if true;
        allow write: if isRecruitingStaff(playerId);
      }
      
      match /evaluations/{evalId} {
        allow read: if true;
        allow write: if isRecruitingStaff(playerId);
      }
      
      match /videos/{videoId} {
        allow read: if true;
        allow write: if isRecruitingStaff(playerId);
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn() || teamId.startsWith('demo_');
      allow create: if isSignedIn();
      allow update, delete: if isTeamStaff(teamId);

      match /members/{memberId} {
        allow read: if true; 
        allow write: if isTeamStaff(teamId) || isOwner(memberId);
        
        match /signatures/{sigId} {
          allow read: if isSignedIn();
          allow write: if isSignedIn();
        }
      }

      match /documents/{docId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
      }

      match /events/{eventId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
      }

      match /volunteers/{oppId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
      }

      match /fundraising/{fundId} {
        allow read: if true;
        allow write: if isTeamStaff(teamId);
        
        match /donations/{donationId} {
          allow read: if isTeamStaff(teamId);
          allow create: if true; 
          allow update: if isTeamStaff(teamId);
        }
      }

      match /feedPosts/{postId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId) || (isSignedIn() && request.auth.uid == resource.data.authorId);
        
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn();
          allow delete: if isTeamStaff(teamId) || (isSignedIn() && request.auth.uid == resource.data.authorId);
        }
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn() || teamId.startsWith('demo_');
        allow write: if isTeamStaff(teamId);
      }

      match /games/{gameId} {
        allow read: if isSignedIn() || teamId.startsWith('demo_');
        allow write: if isTeamStaff(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn() || teamId.startsWith('demo_');
        allow write: if isTeamStaff(teamId);
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isTeamStaff(teamId) || (isSignedIn() && request.auth.uid in resource.data.memberIds);
        allow delete: if isTeamStaff(teamId);

        match /messages/{msgId} {
          allow read, create: if isSignedIn();
        }
      }

      match /scouting/{scoutId} {
        allow read: if isSignedIn();
        allow write: if isTeamStaff(teamId);
      }

      match /files/{fileId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      
      match /registration/{docId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /registrationEntries/{entryId} {
        allow read: if isSignedIn();
        allow create: if true;
        allow update, delete: if isSignedIn();
      }
    }

    match /facilities/{facId} {
      allow read: if true;
      allow write: if isSignedIn();
      
      match /fields/{fieldId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // Support for collectionGroup queries
    match /{path=**}/donations/{donationId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
  }
}
