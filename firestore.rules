rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      // Robust check for anonymous/custom provider status used in development/demos
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom'
      );
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAnonymous();
      }
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAnonymous();
      }
    }

    // --- Teams Hierarchy ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAnonymous();
      allow update, delete: if isSignedIn() || isAnonymous();

      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Leagues Hierarchy ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAnonymous();
      allow update, delete: if isSignedIn() || isAnonymous();

      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Players Hierarchy ---
    match /players/{playerId} {
      allow read: if isSignedIn() || true; // Public for scouting
      allow create: if isSignedIn() || isAnonymous();
      allow update, delete: if isSignedIn() || isAnonymous();

      match /{allPaths=**} {
        allow read: if isSignedIn() || true;
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Facilities & Fleet ---
    match /facilities/{facilityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() || isAnonymous();
      allow update, delete: if isSignedIn() || isAnonymous();

      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() || isAnonymous(); 
    }
    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn() || isAnonymous();
    }

    // --- Membership Sentinel ---
    match /team_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    // --- Collection Groups (For cross-team auditing) ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/feedPosts/{postId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }
    match /{path=**}/incidents/{incId} {
      allow read: if isSignedIn();
    }

    // Deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}