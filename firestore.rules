rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{allPaths=**} {
      // THE ABSOLUTE NUCLEAR BYPASS FOR DEBUGGING
      // If a permission error happens after this, then the browser is NOT talking 
      // to the Firestore instance we are currently deploying rules to.
      allow read, write: if true;
    }
  }
}