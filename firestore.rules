
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES
     * Hardened for Institutional Audit & High-Performance Coordination
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isDemo(id) {
      return id != null && id.matches('^demo_.*');
    }

    function isMember(tid) {
      return isSignedIn() && (
        isDemo(tid) || 
        exists(/databases/$(database)/documents/team_memberships/$(tid + "_" + request.auth.uid))
      );
    }

    function isAdmin(tid) {
      return isSignedIn() && (
        isDemo(tid) || 
        get(/databases/$(database)/documents/team_memberships/$(tid + "_" + request.auth.uid)).data.role == 'Admin'
      );
    }

    // --- Meta Collections (Publicly Readable) ---

    match /plans/{planId} {
      allow read: if true; 
    }

    match /features/{featureId} {
      allow read: if true;
    }

    // --- User Data ---

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // --- ACL Hub ---

    match /team_memberships/{membershipId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // --- Team & Roster Hubs ---

    match /teams/{tid} {
      allow get, list: if isSignedIn() && (isDemo(tid) || isMember(tid));
      allow create: if isSignedIn(); 
      allow update, delete: if isSignedIn() && (isDemo(tid) || isAdmin(tid));

      match /{allSubcollections=**} {
        allow read: if isSignedIn() && (isDemo(tid) || isMember(tid));
        allow write: if isSignedIn() && (isDemo(tid) || isAdmin(tid));
      }
    }

    // --- Institutional Infrastructure ---

    match /leagues/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /players/{id} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{id} {
      allow read, write: if isSignedIn();
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Collection Group Rules for Auditing & Recruitment ---

    match /{path=**}/invites/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/incidents/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/signatures/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{id} {
      allow read: if isSignedIn();
    }

  }
}
