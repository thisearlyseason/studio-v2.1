rules_version = '2';

/**
 * SquadForge Security Rules
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isTeamMember(data) {
      return isSignedIn() && (
        data.teamMembers[request.auth.uid] != null || 
        data.members[request.auth.uid] != null
      );
    }

    function isTeamAdmin(data) {
      return isSignedIn() && (
        data.teamMembers[request.auth.uid] == 'admin' || 
        data.members[request.auth.uid] == 'admin'
      );
    }

    // --- COLLECTION RULES ---

    /**
     * @description High-priority ownership rule for user profiles.
     * Essential for demo users who have a UID but no email verification.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if isSignedIn();
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
    }

    match /leads/{leadId} {
      allow create: if true;
    }

    match /teams/{teamId} {
      allow get, list: if isSignedIn() && (
        resource == null || 
        resource.data.members[request.auth.uid] != null || 
        resource.data.ownerUserId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.members[request.auth.uid] == 'admin' || 
        resource.data.ownerUserId == request.auth.uid
      );

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
        
        match /evaluations/{evalId} {
          allow read, write: if isTeamAdmin(get(/databases/$(database)/documents/teams/$(teamId)).data);
        }
      }

      match /feedPosts/{postId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();

        match /comments/{commentId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn();
        }
      }

      match /events/{eventId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();

        match /registrations/{regId} {
          allow read, write: if true;
        }
      }

      match /groupChats/{chatId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();

        match /messages/{messageId} {
          allow read, list: if isSignedIn();
          allow create: if isSignedIn();
          allow update, delete: if isSignedIn();
        }
      }

      match /files/{fileId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }

      match /alerts/{alertId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
      }

      match /drills/{drillId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /games/{gameId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /scouting/{reportId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /volunteers/{oppId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /fundraising/{fundId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /equipment/{itemId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /leagues/{leagueId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
      
      match /registration/{document=**} {
        allow read, write: if true;
      }
      
      match /registrationEntries/{entryId} {
        allow read, write: if true;
      }
    }

    match /facilities/{facId} {
      allow read, list: if isSignedIn();
      allow write: if isSignedIn();
      
      match /fields/{fieldId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- COLLECTION GROUP RULES ---

    match /{path=**}/events/{eventId} {
      allow read, list: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read, list: if true;
    }
  }
}