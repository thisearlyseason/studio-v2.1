rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper to check if a user is a member of a team
    function isTeamMember(teamId) {
      return isSignedIn() && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    // Helper to check if a user is an admin of a team
    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'Admin' ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid
      );
    }

    // --- User Profiles ---
    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
      
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Players ---
    match /players/{playerId} {
      allow read: if isSignedIn();
      // Allow creation during signup or parent registration
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == resource.data.parentId || request.auth.uid == resource.data.userId);
      
      match /recruitingProfile/{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      
      match /evaluations/{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
      
      match /videos/{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        // Allow users to add themselves or admins to add others
        allow create: if isSignedIn(); 
        allow update: if isTeamAdmin(teamId) || isOwner(memberId);
        allow delete: if isTeamAdmin(teamId);
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /registrations/{allPaths=**} {
          allow read: if isTeamAdmin(teamId);
          allow create: if true; 
        }
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update: if isTeamMember(teamId) && (request.auth.uid == resource.data.authorId || isTeamAdmin(teamId));
        allow delete: if isTeamAdmin(teamId) || (isSignedIn() && request.auth.uid == resource.data.authorId);

        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow delete: if isTeamAdmin(teamId) || (isSignedIn() && request.auth.uid == resource.data.authorId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
        allow create: if isTeamMember(teamId);
        allow update: if isSignedIn() && (request.auth.uid in resource.data.memberIds || isTeamAdmin(teamId));
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read, create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)/groupChats/$(chatId)).data.memberIds;
          allow update, delete: if isSignedIn() && request.auth.uid == resource.data.authorId;
        }
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow delete: if isTeamAdmin(teamId) || (isSignedIn() && request.auth.uid == resource.data.uploadedBy);
      }

      match /drills/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /games/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /volunteers/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId);
      }

      match /fundraising/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId) || isTeamMember(teamId);
      }

      match /equipment/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /incidents/{allPaths=**} {
        allow read, write: if isTeamAdmin(teamId);
      }
      
      match /alerts/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
      
      match /documents/{allPaths=**} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
    }

    // --- Team Memberships (Global) ---
    match /team_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- Facilities ---
    match /facilities/{facId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /fields/{fieldId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    // --- Leagues ---
    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.creatorId;
      
      match /registration/{allPaths=**} {
        allow read: if true; 
        allow write: if isSignedIn();
      }
      
      match /registrationEntries/{allPaths=**} {
        allow read: if isSignedIn();
        allow create: if true;
        allow update: if isSignedIn();
      }
      
      match /payments/{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /leagues/global/invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
    }
    match /features/{featureId} {
      allow read: if true;
    }

    // --- Collection Groups ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    // Catch-all
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
