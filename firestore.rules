
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE HELPERS ---
    
    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Super Admin list for platform oversight and demo stability
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == '3Dybqi6vkHNUQQM66jiEZWfmwsW2' ||
        request.auth.uid == 'wnvOuvwmoUhS5U4kdaBrZz7tGbF3' ||
        request.auth.uid == 'PtT54iDDtUML1wslbZzxjDgbrFp1' ||
        request.auth.uid == 'zGh7D5JfrFOkxhVJr79gtbzHPVC3' ||
        request.auth.uid == 'E4EqTVTsEdfLI4rLEkMPHjeyxeJ2'
      );
    }

    // --- COLLECTION GROUP SUPPORT ---
    // Explicit matches for "list proving" across hierarchies
    
    match /{allPaths=**}/registrationEntries/{entryId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
    }
    
    match /{allPaths=**}/members/{memberId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
    }

    match /{allPaths=**}/events/{eventId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
    }

    match /{allPaths=**}/alerts/{alertId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
    }

    // --- TOP LEVEL COLLECTIONS ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if isSignedIn() || isSuperAdmin();
      }
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if isSignedIn() || isSuperAdmin();
      }
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if isSignedIn() || isSuperAdmin();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn() || isSuperAdmin();
      match /{allPaths=**} {
        allow read, write: if isSignedIn() || isSuperAdmin();
      }
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
