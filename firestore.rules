rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    // Explicit matches for collections are required to satisfy Firestore's 'List Proving'
    // mechanism, ensuring collection-wide queries are statically authorized.

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Explicit subcollection matches for listing
      match /registrationEntries/{id} { allow read, write: if isSignedIn(); }
      match /registration/{id} { allow read, write: if isSignedIn(); }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      // Explicit subcollection matches for listing
      match /members/{id} { allow read, write: if isSignedIn(); }
      match /events/{id} { allow read, write: if isSignedIn(); }
      match /games/{id} { allow read, write: if isSignedIn(); }
      match /alerts/{id} { allow read, write: if isSignedIn(); }
      match /groupChats/{id} { allow read, write: if isSignedIn(); }
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONNEL & PRIVATE DATA ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Explicit subcollection matches for listing
      match /teamMemberships/{id} { allow read, write: if isOwner(userId); }
      match /hiddenChats/{id} { allow read, write: if isOwner(userId); }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- STATIC CATALOGS ---

    match /plans/{planId} {
      allow read: if true;
    }

    match /features/{featureId} {
      allow read: if true;
    }

    // --- COLLECTION GROUP ACCESS ---
    // Authorized for Master Intelligence queries in the Club/Family hubs
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}