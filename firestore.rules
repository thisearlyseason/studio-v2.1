rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    
    // Leagues Hub - Simplified for Provable Listing
    match /leagues/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Teams Hub - Simplified for Provable Listing
    match /teams/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /userProfiles/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // --- GLOBAL REPOSITORIES ---

    match /plans/{allPaths=**} { allow read: if true; allow write: if isSignedIn(); }
    match /features/{allPaths=**} { allow read: if true; allow write: if isSignedIn(); }
    match /facilities/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /players/{allPaths=**} { allow read, write: if isSignedIn(); }
    
    match /team_memberships/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /subscriptions/{allPaths=**} { allow read, write: if isSignedIn(); }

    // --- COLLECTION GROUPS ---
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}