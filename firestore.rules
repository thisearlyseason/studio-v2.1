rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SquadForge Security Rules
     * Optimized for reliability and performance.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Membership check using the dedicated sub-collection
    function isMemberOfTeam(teamId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    // Role check using the dedicated sub-collection document
    function isAdminOfTeam(teamId) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'Admin';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, create, update: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
    }

    match /teams/{teamId} {
      allow list: if isSignedIn() && resource.data.members[request.auth.uid] != null;
      allow get: if isSignedIn() && (resource.data.members[request.auth.uid] != null || isMemberOfTeam(teamId));
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.members[request.auth.uid] == 'Admin';

      match /members/{memberId} {
        allow list, get: if isMemberOfTeam(teamId) || (isSignedIn() && request.auth.uid == memberId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /feedPosts/{postId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        // Allow members to update posts (for liking)
        allow update: if isMemberOfTeam(teamId);
        allow delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow list, get: if isMemberOfTeam(teamId);
          allow create: if isMemberOfTeam(teamId);
          allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }

      match /events/{eventId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /games/{gameId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /alerts/{alertId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create, update, delete: if isAdminOfTeam(teamId);
      }

      match /files/{fileId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.uploadedBy == request.auth.uid);
      }

      match /groupChats/{chatId} {
        allow list, get: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        allow update, delete: if isAdminOfTeam(teamId);

        match /messages/{messageId} {
          allow list, get: if isMemberOfTeam(teamId);
          allow create: if isMemberOfTeam(teamId);
          allow update, delete: if isAdminOfTeam(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }
    }
  }
}
