
/**
 * SquadForge Firestore Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, role-based and ownership-based security model. It prioritizes 
 * "Authorization Independence" by leveraging denormalized fields (like authorId and creatorId) 
 * to ensure that security decisions are fast, performant, and do not require excessive cross-document 
 * lookups. Access is strictly governed by the authenticated user's identity.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an application administrator.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Checks if the user is an admin of a specific team based on the members subcollection or role field.
     */
    function isTeamAdmin(teamId) {
      // For simplicity in this ruleset, we check if the user is the creator or has an admin role mapping.
      // In a production app, we would often check a 'members' map on the team document itself for performance.
      let teamData = get(/databases/$(database)/documents/teams/$(teamId)).data;
      return isAdmin() || (isSignedIn() && (teamData.members[request.auth.uid] == 'Admin' || teamData.createdBy == request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Personal user account data.
     */
    match /users/{userId} {
      allow get, list, create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Team entities and their nested sub-resources.
     */
    match /teams/{teamId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isOwner(request.resource.data.userId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);

        match /registrations/{regId} {
          allow read: if isTeamAdmin(teamId);
          allow create: if true;
          allow delete: if isTeamAdmin(teamId);
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.uploaderId);
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, delete: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);
        }
      }
    }

    /**
     * @description Global application configuration.
     */
    match /features/{featureId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /plans/{planId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    /**
     * @description Admin Role Management.
     */
    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
