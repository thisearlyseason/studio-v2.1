rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' ||
        request.auth.token.email == 'test@gmail.com'
      );
    }

    function isTeamStaff(teamId) {
      let team = get(/databases/$(database)/documents/teams/$(teamId));
      return isSignedIn() && (
        isSuperAdmin() || 
        (team != null && (team.data.ownerUserId == request.auth.uid || team.data.createdBy == request.auth.uid))
      );
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /households/{householdId} {
      allow read, write: if isOwner(householdId) || (isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.parentIds);
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.parentId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
    }

    match /teams/{teamId} {
      allow get: if true; // Allow public get for spectator/registration hubs
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamStaff(teamId);

      match /registration/{docId} {
        allow read: if true;
      }
      
      match /registrationEntries/{entryId} {
        allow create: if true;
        allow read, write: if isTeamStaff(teamId);
      }

      match /alerts/{alertId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn(); 
        allow update, delete: if isTeamStaff(teamId);
      }

      match /members/{memberId} {
        allow read, list: if true; // Allow public roster viewing for recruiting/scouting
        allow create: if isSignedIn(); 
        allow update, delete: if isTeamStaff(teamId) || isOwner(memberId);

        match /private/evaluation {
          allow read, write: if isTeamStaff(teamId);
        }
        
        match /signatures/{docId} {
          allow read: if isSignedIn();
          allow write: if isOwner(memberId) || isTeamStaff(teamId);
        }
      }

      match /documents/{docId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
        
        match /signatures/{sigId} {
          allow read, list: if isSignedIn();
          allow write: if isSignedIn(); 
        }
      }

      match /events/{eventId} {
        allow get: if true; // Allow public viewing for tournament hubs
        allow read, list: if isSignedIn() || true; 
        allow create: if isSignedIn();
        allow update: if true; // Allow public scoring and waiver signing
        allow delete: if isTeamStaff(teamId);
        
        match /registrations/{regId} {
          allow create: if true;
          allow read, write: if isTeamStaff(teamId);
        }
      }

      match /games/{gameId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
      }

      match /equipment/{itemId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
      }

      match /volunteers/{oppId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId) || isSignedIn(); 
      }

      match /fundraising/{fundId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId) || isSignedIn(); 
      }

      match /drills/{drillId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
      }

      match /scouting/{reportId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
      }

      match /feedPosts/{postId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn(); 
        
        match /comments/{commentId} {
          allow read, list: if isSignedIn();
          allow write: if isSignedIn();
        }
      }

      match /groupChats/{chatId} {
        allow read, write: if isSignedIn();
        
        match /messages/{msgId} {
          allow read, write: if isSignedIn();
        }
      }

      match /files/{fileId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId) || isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || resource.data.clubId == request.auth.uid;
      
      match /fields/{fieldId} {
        allow read, list: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /leagues/{leagueId} {
      allow get: if true; // Public spectator views
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if true; // Public scoring entry
      
      match /registrationEntries/{entryId} {
        allow create: if true;
        allow read, write: if isSignedIn();
      }

      match /registration/{protocolId} {
        allow read: if true; 
        allow create: if isSignedIn();
        allow update, delete: if isSuperAdmin() || resource.data.creatorId == request.auth.uid;
      }
    }

    match /leagues/global/invites/{inviteId} {
      allow create, read, list: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin(); 
    }

    match /subscriptions/{subId} {
      allow read: if isOwner(subId) || isSuperAdmin();
      allow write: if isSuperAdmin() || isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read, list: if isSignedIn();
      allow create: if true;
    }
  }
}