/**
 * SquadForge Firestore Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, role-based and ownership-based security model. It prioritizes 
 * "Authorization Independence" by leveraging denormalized fields (like authorId and creatorId) 
 * to ensure that security decisions are fast, performant, and do not require excessive cross-document 
 * lookups. Access is strictly governed by the authenticated user's identity.
 *
 * DATA STRUCTURE:
 * - /users/{userId}: Private user profiles managed by the owner.
 * - /teams/{teamId}: Collaborative group spaces containing sub-resources (Members, Events, Posts, etc.).
 * - /features & /plans: Global application configuration for subscription management.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an application administrator.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Verifies ownership of an existing document before modification or deletion.
     */
    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    /**
     * @description Checks if the authenticated user is a member of the specified group chat.
     */
    function isChatMember(chatId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberIds;
    }

    /**
     * @description Checks if the user is an admin of a specific team based on the members map.
     */
    function isTeamAdmin(teamId) {
      let teamData = get(/databases/$(database)/documents/teams/$(teamId)).data;
      return isAdmin() || (isSignedIn() && (teamData.members[request.auth.uid] == 'Admin' || teamData.creatorId == request.auth.uid || teamData.createdBy == request.auth.uid));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Personal user account data.
     */
    match /users/{userId} {
      allow get, list, create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Team entities and their nested sub-resources.
     */
    match /teams/{teamId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      /**
       * @description Team Roster Members.
       */
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamAdmin(teamId) || isOwner(resource.data.userId);
      }

      /**
       * @description Scheduled team events and matches.
       */
      match /events/{eventId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isTeamAdmin(teamId);

        match /registrations/{regId} {
          allow read: if isTeamAdmin(teamId);
          allow create: if true; // Public Registration
          allow delete: if isTeamAdmin(teamId);
        }
      }

      /**
       * @description Recorded match results.
       */
      match /games/{gameId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isTeamAdmin(teamId);
      }

      /**
       * @description Training library drills.
       */
      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isTeamAdmin(teamId);
      }

      /**
       * @description Shared squad repository files.
       */
      match /files/{fileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.uploaderId);
      }

      /**
       * @description High priority broadcasts.
       */
      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, delete: if isTeamAdmin(teamId);
      }

      /**
       * @description Activity feed posts.
       */
      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);
        }
      }

      /**
       * @description Group messaging channels.
       */
      match /groupChats/{chatId} {
        allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds || isTeamAdmin(teamId));
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (request.auth.uid in resource.data.memberIds || isTeamAdmin(teamId));
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || isOwner(resource.data.authorId);
        }
      }
    }

    /**
     * @description Global application features metadata.
     */
    match /features/{featureId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    /**
     * @description Global application subscription plans.
     */
    match /plans/{planId} {
      allow get: if true;
      allow list: if resource.data.isPublic == true || isAdmin();
      allow write: if isAdmin();
    }

    /**
     * @description Admin Role Management.
     */
    match /roles_admin/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}