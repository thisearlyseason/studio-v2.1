
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && 
             request.auth.token.get('email', '') in ['thisearlyseason@gmail.com', 'test@gmail.com'];
    }

    function isDemoTeam(teamId) {
      // Robust prefix check using startsWith for version 2 compatibility
      return teamId != null && teamId.startsWith('demo_');
    }

    function isAdmin(teamId) {
      // Prioritize demo and superadmin checks to avoid unnecessary exists() calls
      return isSignedIn() && (
        isDemoTeam(teamId) ||
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
          (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.get('role', '') == 'Admin')
        ))
      );
    }

    // Collection Group Queries - Recruitment Ledger
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn() && (
        resource.data.get('assigned_team_owner_id', '') == request.auth.uid || 
        isSuperAdmin() ||
        isDemoTeam(resource.data.get('assigned_team_id', ''))
      );
      allow update: if isSignedIn() && (
        resource.data.get('assigned_team_owner_id', '') == request.auth.uid ||
        isSuperAdmin() ||
        isDemoTeam(resource.data.get('assigned_team_id', ''))
      );
      allow delete: if isSuperAdmin();
    }

    match /players/{playerId} {
      allow read: if isSignedIn() && (
        resource.data.get('parentId', '') == request.auth.uid || 
        resource.data.get('userId', '') == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.get('parentId', '') == request.auth.uid || 
        resource.data.get('userId', '') == request.auth.uid
      );
    }

    match /families/{familyId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.get('parentId', '') == request.auth.uid || isSuperAdmin()
      );
    }

    match /waivers/{waiverId} {
      allow read: if isSignedIn() && (
        resource.data.get('signedByUserId', '') == request.auth.uid || isSuperAdmin()
      );
      allow create: if isSignedIn() && (
        (request.resource.data.get('signedByRole', '') == 'player' && request.resource.data.get('signedByUserId', '') == request.auth.uid) ||
        (request.resource.data.get('signedByRole', '') == 'parent' && request.resource.data.get('signedByUserId', '') == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isDemoTeam(teamId) || isAdmin(teamId);
      allow write: if isDemoTeam(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isDemoTeam(teamId) || isAdmin(teamId) || isOwner(memberId) || 
                     (exists(/databases/$(database)/documents/players/$(memberId)) && 
                      get(/databases/$(database)/documents/players/$(memberId)).data.get('parentId', '') == request.auth.uid);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isDemoTeam(teamId) || isAdmin(teamId);
        
        match /registrations/{regId} {
          allow read, write: if isSignedIn();
        }
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, update: if isDemoTeam(teamId) || isAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isDemoTeam(teamId) || isAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow write: if isDemoTeam(teamId) || isAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow write: if isDemoTeam(teamId) || isAdmin(teamId);
        
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isDemoTeam(teamId) || isAdmin(teamId) || resource.data.authorId == request.auth.uid;
        }
      }

      match /groupChats/{chatId} {
        // Explicit list and get permissions for demo sessions
        allow list: if isSignedIn() && (isDemoTeam(teamId) || isSuperAdmin() || exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)));
        
        allow get: if isSignedIn() && (
          isDemoTeam(teamId) || 
          isSuperAdmin() || 
          request.auth.uid in resource.data.get('memberIds', []) || 
          exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
        );
        
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (isDemoTeam(teamId) || isAdmin(teamId) || request.auth.uid in resource.data.get('memberIds', []));
        
        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isDemoTeam(teamId) || isAdmin(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isSuperAdmin());
      
      match /registration/{config} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid);
      }

      match /registrationEntries/{entryId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid ||
          resource.data.get('assigned_team_owner_id', '') == request.auth.uid ||
          isDemoTeam(resource.data.get('assigned_team_id', ''))
        );
        allow create: if true; 
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid ||
          resource.data.get('assigned_team_owner_id', '') == request.auth.uid ||
          isDemoTeam(resource.data.get('assigned_team_id', ''))
        );
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid);
      }

      match /invites/{inviteId} {
        allow read: if isSignedIn() && (
          request.auth.token.get('email', '') != null &&
          request.auth.token.email.lower() == resource.data.get('invitedEmail', '').lower() ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid ||
          isSuperAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          (request.auth.token.get('email', '') != null && request.auth.token.email.lower() == resource.data.get('invitedEmail', '').lower()) ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.get('creatorId', '') == request.auth.uid
        );
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }
  }
}
