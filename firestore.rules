
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CRITICAL: Top-level Collection Group rule for global tournament discovery & Public Spectator Hub
    match /{path=**}/events/{eventId} {
      allow read: if request.auth != null || (resource != null && resource.data.isTournament == true);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid
      );
    }

    function isAdmin(teamId) {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com' ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
        get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.role == 'Admin'
      );
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isOwner(memberId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow create: if isAdmin(teamId);
        allow update: if isTeamMember(teamId); // For comments, tags, and annotations
        allow delete: if isAdmin(teamId);
      }

      match /events/{eventId} {
        allow update: if isTeamMember(teamId); // For RSVPs
        allow create, delete: if isAdmin(teamId);
        
        match /registrations/{regId} {
          allow create: if true; 
          allow read, delete: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow create, delete: if isAdmin(teamId);
        allow update: if isTeamMember(teamId); // Required for likes and poll votes
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow write: if isTeamMember(teamId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamMember(teamId);
        match /messages/{messageId} {
          allow read, write: if isTeamMember(teamId);
        }
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isAdmin(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid);

      match /invites/{inviteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }
  }
}
