rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES
     * Hardened for Institutional Audit & High-Performance Coordination
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the user is a member of a specific team using the flat ACL collection.
    // Optimized for demo bypass to prevent synchronization loops.
    function isTeamMember(teamId) {
      return isSignedIn() && (
        teamId.matches('^demo_.*') || 
        exists(/databases/$(database)/documents/team_memberships/$(teamId + "_" + request.auth.uid))
      );
    }

    // Checks if the user has the 'Admin' role within a specific team.
    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        teamId.matches('^demo_.*') || 
        get(/databases/$(database)/documents/team_memberships/$(teamId + "_" + request.auth.uid)).data.role == 'Admin'
      );
    }

    // Securely checks membership for chat-related entities using denormalized member lists.
    function isChatMember(data) {
      return isSignedIn() && (request.auth.uid in data.memberIds);
    }

    // --- Meta Collections (Publicly Readable) ---

    match /plans/{planId} {
      allow read: if true; 
    }

    match /features/{featureId} {
      allow read: if true;
    }

    // --- User & Household Data ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
      
      match /profiles/{profileId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.id == userId;
        allow update, delete: if isOwner(userId);
      }

      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }

      match /team_availabilities/{availabilityId} {
        allow read: if isOwner(userId) || isTeamAdmin(resource.data.teamId);
        allow write: if isOwner(userId);
      }
    }

    // --- Team & Roster Hubs ---

    match /team_memberships/{membershipId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /teams/{teamId} {
      allow get, list: if isTeamMember(teamId);
      allow create: if isSignedIn(); 
      allow update, delete: if isTeamAdmin(teamId);

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /members/{memberId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId) || isOwner(resource.data.userId);
      }

      match /feedPosts/{postId} {
        allow get, list: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamMember(teamId) && (resource.data.authorId == request.auth.uid || isTeamAdmin(teamId));

        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow delete: if isTeamMember(teamId) && (resource.data.authorId == request.auth.uid || isTeamAdmin(teamId));
        }
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdmin(teamId);

        match /rsvps/{userId} {
          allow read: if isTeamMember(teamId);
          allow write: if isTeamMember(teamId) && isOwner(userId);
        }
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow delete: if isTeamMember(teamId) && (resource.data.uploadedBy == request.auth.uid || isTeamAdmin(teamId));
      }

      match /group_chats/{chatId} {
        allow get, list: if isTeamMember(teamId) && isChatMember(resource.data);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamMember(teamId) && isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isChatMember(resource.data);
          allow create: if isChatMember(request.resource.data);
        }
      }
    }

    // --- Collection Group Rules for Auditing ---

    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }

  }
}