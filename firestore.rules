rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    
    // Leagues Hub - Explicit matching for List Proving
    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registrationEntries/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registration/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/members/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/events/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /leagues/{leagueId}/payments/{id} {
      allow read, write: if isSignedIn();
    }

    // Teams Hub - Explicit matching for List Proving
    match /teams/{teamId} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/members/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/events/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/feedPosts/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/groupChats/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/incidents/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/files/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/drills/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/equipment/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/volunteers/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/fundraising/{id} {
      allow read, write: if isSignedIn();
    }
    
    match /teams/{teamId}/documents/{id} {
      allow read, write: if isSignedIn();
    }

    // Recursive fallback for nested structures
    match /leagues/{leagueId}/{allPaths=**} { allow read, write: if isSignedIn(); }
    match /teams/{teamId}/{allPaths=**} { allow read, write: if isSignedIn(); }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/teamMemberships/{id} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/hiddenChats/{id} {
      allow read, write: if isOwner(userId);
    }
    
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    // --- GLOBAL REPOSITORIES ---

    match /plans/{planId} { allow read: if true; allow write: if isSignedIn(); }
    match /features/{featureId} { allow read: if true; allow write: if isSignedIn(); }
    match /facilities/{facilityId} { 
      allow read, write: if isSignedIn(); 
      match /{allPaths=**} { allow read, write: if isSignedIn(); }
    }
    match /players/{playerId} { 
      allow read, write: if isSignedIn(); 
      match /{allPaths=**} { allow read, write: if isSignedIn(); }
    }
    match /team_memberships/{membershipId} { allow read, write: if isSignedIn(); }
    match /subscriptions/{subId} { allow read, write: if isSignedIn(); }

    // --- COLLECTION GROUPS ---
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}