rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /teamMemberships/{tid} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Global Catalog Rules
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    match /features/{featureId} {
      allow read: if isSignedIn();
      allow write: if request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Managed by backend webhooks
    }

    // --- Collection Group Rules (for cross-squad/club auditing) ---

    match /{path=**}/signatures/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/incidents/{incidentId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}