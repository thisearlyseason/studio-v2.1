rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && 
        (request.auth.token.get('email', '').lower() == 'thisearlyseason@gmail.com' || 
         request.auth.token.get('email', '').lower() == 'test@gmail.com');
    }

    function isAdmin(teamId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('members', {}).get(request.auth.uid, null) == 'Admin'
        ))
      );
    }

    // Collection Group Queries - Recruitment Ledger
    // Optimized for stateless query verification
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn() && (
        resource.data.assigned_team_owner_id == request.auth.uid || 
        isSuperAdmin() ||
        // Allow demo users to audit their guest rosters based on stateless ID pattern
        (resource.data.assigned_team_id.startsWith('demo_guest_'))
      );
    }

    // New Legally Safe Collections for Minors
    match /players/{playerId} {
      allow read: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    match /families/{familyId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.parentId == request.auth.uid || isSuperAdmin()
      );
    }

    match /waivers/{waiverId} {
      allow read: if isSignedIn() && (
        resource.data.signedByUserId == request.auth.uid || isSuperAdmin()
      );
      allow create: if isSignedIn() && (
        (request.resource.data.signedByRole == 'player' && request.resource.data.signedByUserId == request.auth.uid) ||
        (request.resource.data.signedByRole == 'parent' && request.resource.data.signedByUserId == request.auth.uid)
      );
    }

    // Existing Collections
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read: if isOwner(userId) || isSuperAdmin();
        allow write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isOwner(memberId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow create, delete: if isAdmin(teamId);
        allow update: if isSignedIn();
        
        match /registrations/{regId} {
          allow read, write: if isSignedIn();
        }
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create: if isAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId);
        
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isAdmin(teamId) || resource.data.authorId == request.auth.uid;
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn() && request.auth.uid in resource.data.memberIds;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && request.auth.uid in resource.data.memberIds;
        
        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isSuperAdmin());
      
      match /registration/{config} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
      }

      match /registrationEntries/{entryId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid ||
          resource.data.assigned_team_owner_id == request.auth.uid
        );
        allow create: if true; // Public signups
        allow update: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid);
      }

      match /invites/{inviteId} {
        allow read: if isSignedIn() && (
          resource.data.invitedEmail.lower() == request.auth.token.get('email', '').lower() ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid ||
          isSuperAdmin()
        );
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          resource.data.invitedEmail.lower() == request.auth.token.get('email', '').lower() ||
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid
        );
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }
  }
}