rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Tactical Helpers ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      // Hardened check for anonymous/custom provider status used in development/demos
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom' ||
        request.auth.token.firebase.sign_in_provider == 'none'
      );
    }

    // --- Institutional Hierarchy: Leagues ---
    
    match /leagues {
      allow list: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow get, write: if isSignedIn();
    }

    match /leagues/{leagueId}/invites {
      allow list: if isSignedIn();
    }

    match /leagues/{leagueId}/invites/{id} {
      allow get, create, update, delete: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registration {
      allow list: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registration/{id} {
      allow get, create, update, delete: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registrationEntries {
      allow list: if isSignedIn();
    }
    
    match /leagues/{leagueId}/registrationEntries/{id} {
      allow get, create, update, delete: if isSignedIn();
    }

    // --- Tactical Hierarchy: Teams ---
    
    match /teams {
      allow list: if isSignedIn();
    }

    match /teams/{teamId} {
      allow get, write: if isSignedIn();
      
      // Recursive safety for all nested squad data
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Personal Infrastructure: User Profiles ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Global Athlete Repository ---
    
    match /players/{playerId} {
      allow read, write: if isSignedIn() || isAnonymous();
      match /{allPaths=**} {
        allow read, write: if isSignedIn() || isAnonymous();
      }
    }

    // --- Physical Infrastructure: Facilities ---
    
    match /facilities {
      allow list: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow get, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- Economy: Billing Plans ---
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAnonymous() || isSignedIn();
    }

    // --- Global Sentinels ---
    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- Cross-Squad Aggregation (Collection Groups) ---
    match /{path=**}/events/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/signatures/{id} {
      allow read, write: if isSignedIn();
    }

    // --- Global Default Deny ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
