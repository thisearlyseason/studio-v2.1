rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      // Robust check for anonymous/custom provider status used in development/demos
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom' ||
        request.auth.token.firebase.sign_in_provider == 'none'
      );
    }

    // --- Unified Organizational Hierarchies ---
    // Using top-level recursive wildcards to ensure subcollection listing (like leagues/global/invites)
    // and deep document access for all authenticated squad members.
    
    match /leagues/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /teams/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /players/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /plans/{allPaths=**} {
      allow read: if true;
      allow write: if isAnonymous() || isSignedIn();
    }

    // --- Team Memberships (Sentinels) ---
    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- Collection Groups (Master View & Global Aggregation) ---
    // Essential for the Household Hub and Master Calendar aggregation queries.
    
    match /{path=**}/events/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/members/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{id} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{id} {
      allow read, write: if isSignedIn();
    }
    match /{path=**}/incidents/{id} {
      allow read, write: if isSignedIn();
    }

    // Deny by default for any unexpected root paths to maintain QAP compliance
    match /{path=**} {
      allow read, write: if false;
    }
  }
}