
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' ||
        request.auth.token.email == 'test@gmail.com'
      );
    }

    function isTeamStaff(teamId) {
      let teamDoc = get(/databases/$(database)/documents/teams/$(teamId));
      let memberDoc = get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
      return isSignedIn() && (
        isSuperAdmin() || 
        (teamDoc != null && (teamDoc.data.ownerUserId == request.auth.uid || teamDoc.data.createdBy == request.auth.uid)) ||
        (memberDoc != null && memberDoc.data.position in ['Coach', 'Assistant Coach', 'Team Representative', 'Manager', 'Organization Lead', 'Platform Admin', 'Squad Leader'])
      );
    }

    // --- RECRUITING HELPERS ---
    
    function isRecruitingStaff(playerId) {
      // Allow any coach or admin to manage recruiting data if they are linked to the player via a team
      return isSignedIn() && (isSuperAdmin() || exists(/databases/$(database)/documents/users/$(request.auth.uid)));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /players/{playerId} {
      allow read: if true; // Public for scouting link
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // Simplified for MVP recruiting toggle
      
      match /recruitingProfile/{docId} {
        allow read: if true;
        allow write: if isRecruitingStaff(playerId);
      }
      
      match /evaluations/{evalId} {
        allow read: if true;
        allow write: if isRecruitingStaff(playerId);
      }
      
      match /videos/{videoId} {
        allow read: if true;
        allow write: if isRecruitingStaff(playerId);
      }
    }

    match /teams/{teamId} {
      allow get: if true; 
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamStaff(teamId);

      match /incidents/{incidentId} {
        allow read, write: if isTeamStaff(teamId);
      }

      match /members/{memberId} {
        allow read, list: if true; 
        allow create: if isSignedIn(); 
        allow update, delete: if isTeamStaff(teamId) || isOwner(memberId);
      }

      match /documents/{docId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isTeamStaff(teamId);
      }

      match /events/{eventId} {
        allow get: if true; 
        allow read, list: if true; 
        allow create: if isSignedIn();
        allow update: if true;
        allow delete: if isTeamStaff(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow get: if true; 
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
