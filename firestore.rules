rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && 
        (request.auth.token.get('email', '').lower() == 'thisearlyseason@gmail.com' || 
         request.auth.token.get('email', '').lower() == 'test@gmail.com');
    }

    function isAdmin(teamId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('members', {}).get(request.auth.uid, null) == 'Admin'
        ))
      );
    }

    // New Legally Safe Collections for Minors
    match /players/{playerId} {
      allow read: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.parentId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    match /families/{familyId} {
      allow read, write: if isSignedIn() && (
        resource == null || resource.data.parentId == request.auth.uid || isSuperAdmin()
      );
    }

    match /waivers/{waiverId} {
      allow read: if isSignedIn() && (
        resource.data.signedByUserId == request.auth.uid || isSuperAdmin()
      );
      allow create: if isSignedIn() && (
        // Adults sign for themselves
        (request.resource.data.signedByRole == 'player' && request.resource.data.signedByUserId == request.auth.uid) ||
        // Parents sign for their children
        (request.resource.data.signedByRole == 'parent' && request.resource.data.signedByUserId == request.auth.uid)
      );
    }

    // Existing Collections
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isOwner(memberId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow create, delete: if isAdmin(teamId);
        allow update: if isSignedIn();
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isSuperAdmin());
    }

    match /plans/{planId} {
      allow get, list: if true;
    }
  }
}
