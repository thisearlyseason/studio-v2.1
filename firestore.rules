
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Use get() with a default to safely handle anonymous or incomplete auth tokens
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com'
      );
    }

    // CRITICAL: Support for collectionGroup queries on events (External Invitations)
    // This MUST be defined at the top level with the recursive wildcard {path=**}
    // to authorize global discovery across all team documents.
    match /{path=**}/events/{eventId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && (resource.data.ownerUserId == request.auth.uid || resource.data.createdBy == request.auth.uid));

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /events/{eventId} {
        // Explicitly allow read for scoped queries
        allow read: if isSignedIn();
        
        // write handled by parent/specific rules
        allow write: if isAdmin() || (isSignedIn() && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid || get(/databases/$(database)/documents/teams/$(teamId)).data.members[request.auth.uid] == 'Admin'));
        
        match /registrations/{regId} {
          allow create: if true; 
          allow read, delete: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
        match /comments/{commentId} {
          allow read, write: if isSignedIn();
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
        match /messages/{messageId} {
          allow read, write: if isSignedIn();
        }
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.creatorId == request.auth.uid);

      match /invites/{inviteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || isSignedIn();
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow get, list, write: if isAdmin();
    }

    match /features/{featureId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
  }
}
