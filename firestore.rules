rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- TACTICAL HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL HIERARCHY ---
    
    // Leagues and their nested coordination data
    match /leagues/{leagueId} {
      // Allow access to the league document itself
      allow read, write: if isSignedIn();
      
      // Explicitly authorize subcollections for listing (List Proving)
      // This covers registrationEntries, invites, events, members, etc.
      match /{collectionName}/{docId} {
        allow read, write: if isSignedIn();
      }
      
      // Fallback for any deeper nesting
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // Teams and their nested operational data
    match /teams/{teamId} {
      // Allow access to the team document itself
      allow read, write: if isSignedIn();
      
      // Explicitly authorize subcollections for listing (List Proving)
      // This covers members, events, files, games, feedPosts, etc.
      match /{collectionName}/{docId} {
        allow read, write: if isSignedIn();
      }
      
      // Fallback for any deeper nesting
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- PERSONAL INFRASTRUCTURE ---
    
    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Explicitly allow listing personal subcollections (memberships, hiddenChats)
      match /{collectionName}/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL REPOSITORIES ---

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    // --- COLLECTION GROUPS ---
    // Critical for cross-squad queries and organizational audits
    
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/feedPosts/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/groupChats/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/games/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}