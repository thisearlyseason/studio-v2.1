
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Public Read for Tournament Events
    match /{path=**}/events/{eventId} {
      allow read: if request.auth != null || (resource != null && resource.data.get('isTournament', false) == true);
      
      // Allow public signatures for tournament team agreements
      allow update: if (resource != null && resource.data.get('isTournament', false) == true) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamAgreements']);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && 
        (request.auth.token.get('email', '').lower() == 'thisearlyseason@gmail.com' || 
         request.auth.token.get('email', '').lower() == 'test@gmail.com');
    }

    // Robust membership check with short-circuiting logic
    function isTeamMember(teamId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        // 1. Cheap stateless check for demo guests (Priority for rapid coordination)
        (teamId.size() >= 15 && 
         teamId[0:11] == 'demo_guest_' && 
         teamId[11:15].lower() == request.auth.uid[request.auth.uid.size() - 4 : request.auth.uid.size()].lower()) ||
        // 2. Check local membership registry
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)) ||
        // 3. Server-side fallback to team document
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('members', {}).get(request.auth.uid, null) != null
        ))
      );
    }

    // Robust admin check
    function isAdmin(teamId) {
      return isSignedIn() && (
        isSuperAdmin() ||
        // 1. Demo guest bypass
        (teamId.size() >= 15 && 
         teamId[0:11] == 'demo_guest_' && 
         teamId[11:15].lower() == request.auth.uid[request.auth.uid.size() - 4 : request.auth.uid.size()].lower()) ||
        // 2. Local membership check for role
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)).data.get('role', 'Member') == 'Admin') ||
        // 3. Server-side check
        (exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid ||
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('members', {}).get(request.auth.uid, null) == 'Admin'
        ))
      );
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isOwner(memberId);
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId) || (resource != null && resource.data.get('isTournament', false) == true);
        allow create, delete: if isAdmin(teamId);
        allow update: if isTeamMember(teamId) || (resource != null && resource.data.get('isTournament', false) == true); 
        
        match /registrations/{regId} {
          allow create: if true; 
          allow read, delete: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow delete: if isAdmin(teamId) || (resource != null && resource.data.get('authorId', '') == request.auth.uid);
        allow update: if isTeamMember(teamId); 
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow write: if isTeamMember(teamId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamMember(teamId);
        
        match /messages/{messageId} {
          allow read, write: if isTeamMember(teamId);
        }
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow write: if isAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow write: if isAdmin(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid || isSuperAdmin());

      match /invites/{inviteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }

      // LEAGUE REGISTRATION RULES
      match /registration/{regId} {
        allow read: if true; // Publicly readable for the signup page
        allow write: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid || isSuperAdmin());
      }

      match /registrationEntries/{entryId} {
        allow create: if true; // Anonymous signups allowed
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid || 
          isSuperAdmin() ||
          // Coaches can read entries explicitly assigned to their team
          (resource.data.status == 'assigned' && isAdmin(resource.data.assigned_team_id))
        );
        allow update: if isSignedIn() && (
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid || 
          isSuperAdmin() ||
          // Coaches can only update status (Accept/Decline) if assigned to their team
          (isAdmin(resource.data.assigned_team_id) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']))
        );
        allow delete: if isSignedIn() && (get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid || isSuperAdmin());
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /subscriptions/{subId} {
      allow read: if isOwner(subId) || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read: if isSuperAdmin();
    }
  }
}
