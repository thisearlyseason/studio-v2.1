
/**
 * SquadForge Firestore Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, role-based and ownership-based security model.
 * It is designed to handle batch operations, collaborative engagement (polls/likes),
 * and dynamic feature gating.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an application administrator (Super Admin).
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'thisearlyseason@gmail.com' || 
        request.auth.token.email.lower() == 'test@gmail.com'
      );
    }

    /**
     * @description Robust check if the user is an admin of a specific team.
     */
    function isTeamAdmin(teamId) {
      let teamPath = /databases/$(database)/documents/teams/$(teamId);
      let teamDoc = exists(teamPath) ? get(teamPath) : null;
      let teamData = teamDoc != null ? teamDoc.data : null;
      
      return isAdmin() || (isSignedIn() && teamData != null && (
        (teamData.members != null && teamData.members[request.auth.uid] == 'Admin') || 
        teamData.createdBy == request.auth.uid || 
        teamData.creatorId == request.auth.uid ||
        teamData.isDemo == true
      ));
    }

    /**
     * @description Ensures the club manager (creator) cannot be deleted.
     */
    function isManager(teamId, memberId) {
      let teamPath = /databases/$(database)/documents/teams/$(teamId);
      let teamData = exists(teamPath) ? get(teamPath).data : null;
      return teamData != null && (teamData.createdBy == memberId || teamData.creatorId == memberId);
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get, list, create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /teams/{teamId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && (memberId == request.auth.uid || isTeamAdmin(teamId));
        allow update: if isSignedIn() && (memberId == request.auth.uid || isTeamAdmin(teamId));
        // Protect manager from deletion by other admins/coaches
        allow delete: if isTeamAdmin(teamId) && (!isManager(teamId, memberId) || isAdmin());
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);

        match /registrations/{regId} {
          allow create: if true; 
          allow read, delete: if isTeamAdmin(teamId);
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.uploaderId == request.auth.uid);
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, delete: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow update: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
