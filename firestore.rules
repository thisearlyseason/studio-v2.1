rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlatformAdmin() {
      return isSignedIn() && (request.auth.token.email == 'thisearlyseason@gmail.com' || request.auth.token.email == 'admin@thesquad.pro');
    }

    // --- Global Catalog Rules (Publicly Readable) ---
    
    match /plans/{allPaths=**} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /features/{allPaths=**} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    // --- Core Entity Rules (Recursive Wildcards) ---

    match /userProfiles/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }

    match /teams/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /leagues/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /players/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /facilities/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Managed by backend webhooks
    }

    // --- Collection Group Rules for Auditing & Cross-Squad Views ---

    match /{path=**}/signatures/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/incidents/{incidentId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/drills/{drillId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/games/{gameId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/feedPosts/{postId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/groupChats/{chatId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/chatMessages/{messageId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/documents/{docId} {
      allow read: if isSignedIn();
    }

    // Catch-all default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}