rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /userProfiles/{userId} {
      allow read, write: if isOwner(userId);
      match /hiddenChats/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /teamMemberships/{tid} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Simplified for MVP coordination
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /fields/{fieldId} {
        allow read, write: if isSignedIn();
      }
    }

    // Global Catalog Rules - Publicly readable for enrollment/onboarding
    match /plans/{document=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    match /features/{document=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.email == 'thisearlyseason@gmail.com';
    }

    match /subscriptions/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Managed by backend webhooks
    }

    // --- Collection Group Rules for Auditing ---

    match /{path=**}/signatures/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/incidents/{incidentId} {
      allow read: if isSignedIn();
    }

    // Catch-all default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}