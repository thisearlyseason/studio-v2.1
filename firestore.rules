
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // CRITICAL: Top-level Collection Group rule for global tournament discovery & Public Spectator Hub
    match /{path=**}/events/{eventId} {
      allow read: if request.auth != null || (resource != null && resource.data.get('isTournament', false) == true);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Optimized Membership Check: Prioritizes local membership registry for instant verification
    // Falls back to team metadata with safe property lookups
    function isTeamMember(teamId) {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)) ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
        request.auth.uid in get(/databases/$(database)/documents/teams/$(teamId)).data.get('members', {})
      );
    }

    // Optimized Admin Check: Supports super-admins and team-level authority with safe token lookups
    function isAdmin(teamId) {
      let userEmail = request.auth.token.get('email', '');
      let isPlatformAdmin = userEmail == 'thisearlyseason@gmail.com' || userEmail == 'test@gmail.com';
      
      return isSignedIn() && (
        isPlatformAdmin ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
        get(/databases/$(database)/documents/teams/$(teamId)).data.get('members', {}).get(request.auth.uid) == 'Admin'
      );
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isAdmin(teamId) || isOwner(memberId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow create: if isAdmin(teamId);
        allow update: if isAdmin(teamId); 
        allow delete: if isAdmin(teamId);
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow write: if isTeamMember(teamId);
        }
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId) || isAdmin(teamId);
        allow create, delete: if isAdmin(teamId);
        allow update: if isTeamMember(teamId) || isAdmin(teamId); 
        
        match /registrations/{regId} {
          allow create: if true; 
          allow read, delete: if isSignedIn();
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId) || isAdmin(teamId);
        allow write: if isAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId) || isAdmin(teamId);
        allow create, update, delete: if isAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId) || isAdmin(teamId);
        allow create: if isAdmin(teamId);
        allow delete: if isAdmin(teamId) || (resource != null && resource.data.get('authorId', '') == request.auth.uid);
        allow update: if isTeamMember(teamId) || isAdmin(teamId); 
        
        match /comments/{commentId} {
          allow read: if isTeamMember(teamId) || isAdmin(teamId);
          allow write: if isTeamMember(teamId) || isAdmin(teamId);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isTeamMember(teamId) || isAdmin(teamId);
        allow create: if isTeamMember(teamId) || isAdmin(teamId);
        allow update, delete: if isTeamMember(teamId) || isAdmin(teamId);
        
        match /messages/{messageId} {
          allow read, write: if isTeamMember(teamId) || isAdmin(teamId);
        }
      }

      match /alerts/{alertId} {
        // Broaden read access for verified members to ensure coordination alerts are never blocked
        allow read, list: if isSignedIn() && (isTeamMember(teamId) || isAdmin(teamId));
        allow write: if isAdmin(teamId);
      }
    }

    match /leagues/{leagueId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.get('creatorId', '') == request.auth.uid);

      match /invites/{inviteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }

    match /subscriptions/{subId} {
      allow read: if isOwner(subId);
      allow write: if false;
    }
  }
}
