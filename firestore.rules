rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAnonymous() {
      // Robust check for anonymous/custom provider status used in development/demos
      return isSignedIn() && (
        request.auth.token.firebase.sign_in_provider == 'anonymous' || 
        request.auth.token.firebase.sign_in_provider == 'custom' ||
        request.auth.token.sign_in_provider == 'anonymous' ||
        request.auth.token.sign_in_provider == 'custom'
      );
    }

    // --- Global Catalog ---
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn() || isAnonymous();
    }
    match /features/{featureId} {
      allow read: if true;
      allow write: if isSignedIn() || isAnonymous();
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAnonymous();
      
      match /{allPaths=**} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAnonymous();
      }
    }

    // --- Unified Hierarchies ---
    // Explicitly using recursive wildcards at the hierarchy root to authorize subcollection listing
    // match /collection/{allPaths=**} covers list and get for all sub-data
    
    match /leagues/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    match /teams/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    match /players/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    match /facilities/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    // --- Membership Sentinel ---
    match /team_memberships/{membershipId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }

    // --- Collection Groups (For Master Calendar & Household Hub) ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/files/{fileId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/signatures/{sigId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }
    match /{path=**}/members/{memberId} {
      allow read: if isSignedIn();
    }
    match /{path=**}/feedPosts/{postId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() || isAnonymous();
    }
    match /{path=**}/incidents/{incId} {
      allow read: if isSignedIn();
    }

    // Deny by default
    match /{path=**} {
      allow read, write: if false;
    }
  }
}