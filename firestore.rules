rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Super admin: verified server-side via Firebase Custom Claims.
    // Set with: admin.auth().setCustomUserClaims(uid, { role: 'superadmin' })
    // This cannot be forged by clients — it's signed into the JWT by Firebase.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.role == 'superadmin';
    }

    function isTeamMember(teamId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    function isTeamOwner(teamId) {
      // Guard: exists() check prevents get().data crash when team doc doesn't exist yet.
      // This happens during seeder race conditions where team-provider subscribes
      // before the batch.commit() completes.
      return isSignedIn() &&
        exists(/databases/$(database)/documents/teams/$(teamId)) &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUserId == request.auth.uid;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSuperAdmin() || (isSignedIn() && isOwner(userId));
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSuperAdmin() || (isSignedIn() && isOwner(userId));
      allow delete: if false; // Never allow client-side user deletion

      // Google OAuth tokens — server-write only via Cloud Functions
      match /tokens/{tokenId} {
        allow read, write: if false;
      }

      // Team membership index — readable by owner
      match /teamMemberships/{teamId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow write: if isSignedIn() && isOwner(userId);
      }
    }

    // ─── Teams ──────────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Owner, any authenticated member, or super admin can read team doc.
      // CRITICAL: resource == null means the document doesn't exist yet (seeder
      // race condition — the onSnapshot fires before batch.commit() finishes).
      // A non-existent doc has zero sensitive data; the response is just
      // "not found". Allowing signed-in reads on null-resource docs is safe.
      allow read: if isSuperAdmin() || (isSignedIn() && (
        resource == null ||  // Doc not yet created — safely return not-found
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.isDemo == true ||
        isTeamMember(teamId)
      ));
      allow create: if isSignedIn() && (
        request.resource.data.ownerUserId == request.auth.uid ||
        // Demo seeder creates teams with fictional ownerUserId (e.g. parent/player demos use
        // a coach stand-in so the guest user doesn't trigger pro-quota enforcement).
        // Any signed-in user may create a demo-flagged team; demo data is ephemeral.
        request.resource.data.isDemo == true
      );
      allow update: if isSuperAdmin() || (isSignedIn() && (
        (resource != null && resource.data.ownerUserId == request.auth.uid) ||
        (resource != null && isTeamMember(teamId))
      ));
      allow delete: if isSuperAdmin() || (isSignedIn() && resource != null && resource.data.ownerUserId == request.auth.uid);

      // Sub-collections: only members can read; only owner can write
      match /members/{memberId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (
          resource == null ||  // Non-existent member doc — safe to read
          resource.data.ownerUserId == request.auth.uid ||
          isTeamMember(teamId)
        ));
        allow write: if isSuperAdmin() || (isSignedIn() && (
          isTeamOwner(teamId) ||
          // During batch-seeding, the team doc is written atomically with members in the same
          // commit. The exists() guard in isTeamOwner() returns false until propagation completes,
          // so we allow writes where the member record itself carries isDemo == true.
          request.resource.data.isDemo == true
        ));

        // Waiver signatures nested under each member
        // Path: teams/{teamId}/members/{memberId}/signatures/{sigId}
        match /signatures/{sigId} {
          allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
          allow write: if isSuperAdmin() || (isSignedIn() && (
            isTeamOwner(teamId) ||
            request.auth.uid == memberId ||
            request.resource.data.isDemo == true
          ));
        }
      }

      match /events/{eventId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || request.resource.data.isDemo == true));

        // Tournament bracket data nested under events
        // Path: teams/{teamId}/events/{eventId}/brackets/{bracketId}
        match /brackets/{bracketId} {
          allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
          allow write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || request.resource.data.isDemo == true));
        }
      }

      match /incidents/{incidentId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || request.resource.data.isDemo == true));
      }

      match /games/{gameId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || request.resource.data.isDemo == true));
      }

      match /fundraising/{fundId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));

        match /donations/{donationId} {
          allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
          allow write: if isSuperAdmin() || isSignedIn();
        }
      }

      // Catch-all for any other team sub-collections (drills, alerts, equipment, feed, files,
      // documents, practice_templates, volunteers, feedPosts, groupChats, etc.)
      // isDemo flag allows the seeder to write in the same batch before team ownership propagates.
      match /{subCollection}/{docId} {
        allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
        allow write: if isSuperAdmin() || (isSignedIn() && (
          isTeamOwner(teamId) ||
          isTeamMember(teamId) ||
          request.resource.data.isDemo == true
        ));

        // Recursive catch-all for any sub-sub-collection (e.g. groupChats/messages, etc.)
        // Path: teams/{teamId}/{subCollection}/{docId}/{subSubCollection}/{subDocId}
        match /{subSubCollection}/{subDocId} {
          allow read: if isSuperAdmin() || (isSignedIn() && (isTeamOwner(teamId) || isTeamMember(teamId)));
          allow write: if isSuperAdmin() || (isSignedIn() && (
            isTeamOwner(teamId) ||
            isTeamMember(teamId) ||
            request.resource.data.isDemo == true
          ));
        }
      }
    }

    // ─── Players (public scouting profiles) ─────────────────────────────────
    match /players/{playerId} {
      // Public read for recruiting portals (coaches, scouts, parents)
      allow read: if true;
      // Create: must be signed in and set userId to their own UID (prevents impersonation)
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Update/delete: only the profile owner or a superadmin
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      match /{subCollection}/{docId} {
        allow read: if true;
        // Sub-collection writes: only owner or superadmin
        allow write: if isSuperAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/players/$(playerId)).data.userId == request.auth.uid);
      }
    }

    // ─── Leagues ────────────────────────────────────────────────────────────
    match /leagues/{leagueId} {
      // Anyone signed in can read league docs (for registration/standings)
      allow read: if isSignedIn();
      // Only the creator can write league config
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.creatorId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;

      match /registrationEntries/{entryId} {
        // Public write to allow team/player registration from public form
        allow create: if true;
        // Read: any signed-in user (needed for collectionGroup queries in manage-tournaments).
        // The collectionGroup query itself is scoped by teamId/status in the client query.
        allow read: if isSignedIn();
        // Update/delete: only league owner (via creatorId check)
        allow update, delete: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
      }

      match /archived_waivers/{waiverId} {
        allow read, write: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
      }

      match /registration/{configId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && 
          get(/databases/$(database)/documents/leagues/$(leagueId)).data.creatorId == request.auth.uid;
      }

      match /scores/{scoreId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      // Global invites collection
      match /invites/{inviteId} {
        allow read, write: if isSignedIn();
      }
    }

    // ─── Leagues global invites ──────────────────────────────────────────────
    match /leagues/global/invites/{inviteId} {
      allow read, write: if isSignedIn();
    }

    // ─── Plans (pricing/feature tiers) ──────────────────────────────────────
    // Public read: pricing page and unauthenticated visitors need plan metadata.
    // Write is superadmin-only — plan definitions are managed via the admin portal or scripts.
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── Subscriptions audit log (server-write only via webhook) ────────────
    match /subscriptions/{subId} {
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false; // Server-side only
    }

    // ─── Calendar feeds (token-gated) ───────────────────────────────────────
    match /calendarFeeds/{feedId} {
      allow read: if true; // Token is the secret — anyone with the token URL can read
      allow write: if isSignedIn();
    }

    // ─── Volunteers ─────────────────────────────────────────────────────────
    match /volunteerOpportunities/{oppId} {
      allow read: if true; // Public volunteer listings
      allow write: if isSignedIn();

      match /signups/{signupId} {
        allow read: if true;
        allow write: if true; // Public sign-up flow
      }
    }

    // ─── Signatures (global top-level — distinct from team sub-collection) ────
    match /signatures/{sigId} {
      // Owners can read their own; superadmins can read any
      allow read: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Only the signer themselves can write — userId field must match auth uid
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // ─── Alerts ─────────────────────────────────────────────────────────────
    match /alerts/{alertId} {
      // All signed-in users can read alerts for their teams (client-side filters by teamId)
      allow read: if isSignedIn();
      // Write: only superadmin or team owner/member (teamId field must match a team they belong to)
      // This prevents arbitrary alert injection from any signed-in account.
      allow create: if isSuperAdmin() || (
        isSignedIn() && (
          request.resource.data.createdBy == request.auth.uid &&
          (
            request.resource.data.teamId == null ||
            isTeamMember(request.resource.data.teamId) ||
            isTeamOwner(request.resource.data.teamId)
          )
        )
      );
      allow update, delete: if isSuperAdmin() || (
        isSignedIn() && resource.data.createdBy == request.auth.uid
      );
    }

    // ─── Facilities ──────────────────────────────────────────────────────────
    // Coaches/admins manage their own facilities (clubId == their UID).
    match /facilities/{facilityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.clubId == request.auth.uid;
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.clubId == request.auth.uid);

      match /{subCollection}/{docId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/facilities/$(facilityId)).data.clubId == request.auth.uid);
      }
    }

    // ─── Features (feature flag overrides) ──────────────────────────────────
    // Public read so feature checks work unauthenticated. Superadmin-only write.
    match /features/{featureId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // ─── Clubs (Elite Club Hub metadata) ────────────────────────────────────
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSuperAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);

      match /{subCollection}/{docId} {
        allow read: if isSignedIn();
        allow write: if isSuperAdmin() || (isSignedIn() &&
          get(/databases/$(database)/documents/clubs/$(clubId)).data.ownerId == request.auth.uid);
      }
    }

    // ─── Invites (youth player token-gated signup) ───────────────────────────
    // Read: public (token is the secret). Create: any signed-in coach.
    // Update: public redemption flow sets used=true (token is the access secret).
    match /invites/{inviteId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if true;
      allow delete: if isSuperAdmin() || (isSignedIn() && resource.data.createdBy == request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // ─── CollectionGroup Recursive Rules ────────────────────────────────────
    // CRITICAL: Firestore Security Rules REQUIRE recursive wildcard match rules
    // (match /{path=**}/collectionName/{docId}) for EVERY collectionGroup() query.
    // Without these, Firestore reports path "unknown" and denies ALL access —
    // this is what was blocking ALL demo seeds and dashboard queries.
    //
    // Collections covered:
    //   members            — team-provider householdMembers, coaches-corner school roster
    //   events             — team-provider tournament auto-link
    //   signatures         — club/page signature list, family/page waiver history
    //   documents          — club/page document library (ownerUserId scoped)
    //   incidents          — club/page incident log
    //   registrationEntries — team/page & manage-tournaments entry queries
    // ═══════════════════════════════════════════════════════════════════════════

    // members collectionGroup — used by: householdMembersQuery, school roster, auto-link
    match /{path=**}/members/{memberId} {
      // Any signed-in user can query members they're related to.
      // Client-side queries always include a scoping where() clause (parentId, userId, schoolId).
      allow read: if isSignedIn();
      // Writes stay scoped — only the team's owner/member can mutate membership docs.
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // events collectionGroup — used by: tournament auto-link (isTournament == true)
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // signatures collectionGroup — used by: club page (teamId scoped), family page (userId scoped)
    match /{path=**}/signatures/{sigId} {
      // Owners read their own; admins read all; all signed-in can query (client filters by userId)
      allow read: if isSignedIn();
      // Only the signer or an admin can write signature docs
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // documents collectionGroup — used by: club page file library (ownerUserId scoped)
    match /{path=**}/documents/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // incidents collectionGroup — used by: club page incident log (ownerUserId scoped)
    match /{path=**}/incidents/{incidentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // registrationEntries collectionGroup — used by: team/page & manage-tournaments
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
      // Public write: allows team/player sign-up from public registration forms
      allow create: if true;
      allow update, delete: if isSuperAdmin() || isSignedIn();
    }
  }
}