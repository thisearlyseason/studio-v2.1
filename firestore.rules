
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SQUADFORGE SECURITY RULES
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.uid in ['ai2QThECAwfkAFw608m7TgPZTmk2', 'super-admin-uid-placeholder'];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isTeamMember(teamId) {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)));
    }

    function isTeamAdmin(teamId) {
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)/teamMemberships/$(teamId)).data.role == 'Admin');
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSuperAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      match /teamMemberships/{teamId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    match /teams/{teamId} {
      allow get: if isSuperAdmin() || isTeamMember(teamId);
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin() || isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamAdmin(teamId) || (isTeamMember(teamId) && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
          allow update, delete: if isTeamAdmin(teamId) || (isTeamMember(teamId) && resource.data.authorId == request.auth.uid);
        }
      }

      match /events/{eventId} {
        allow read: if isTeamMember(teamId) || get(/databases/$(database)/documents/teams/$(teamId)/events/$(eventId)).data.allowExternalRegistration == true;
        allow create, update, delete: if isTeamAdmin(teamId);

        match /registrations/{regId} {
          allow read: if isTeamAdmin(teamId);
          allow create: if get(/databases/$(database)/documents/teams/$(teamId)/events/$(eventId)).data.allowExternalRegistration == true;
          allow delete: if isTeamAdmin(teamId);
        }
      }

      match /groupChats/{chatId} {
        allow get, list: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isTeamMember(teamId);
          allow create: if isTeamMember(teamId);
        }
      }
      
      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow create: if isTeamMember(teamId);
        allow update, delete: if isTeamAdmin(teamId);
      }

      match /alerts/{alertId} {
        allow read: if isTeamMember(teamId);
        allow create, update, delete: if isTeamAdmin(teamId);
      }
    }
  }
}
