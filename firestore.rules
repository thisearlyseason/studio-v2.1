
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SquadForge Security Rules
     * Optimized for list queries using direct map access for denormalized membership checks.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper for checking membership in documents that have a denormalized 'members' map
    // We use direct indexing which is highly compatible with Firestore's query optimizer.
    function isTeamMember(data) {
      return isSignedIn() && 
             data.members[request.auth.uid] in ['Admin', 'Member'];
    }

    function isTeamAdmin(data) {
      return isSignedIn() && 
             data.members[request.auth.uid] == 'Admin';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      allow list: if false;
    }

    match /teams/{teamId} {
      // Teams themselves are listable if the user is in the members map
      allow get, list: if isTeamMember(resource.data);
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isTeamAdmin(resource.data);

      match /members/{userId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isSignedIn() && isTeamAdmin(request.resource.data);
        allow update: if isTeamAdmin(resource.data) || isOwner(userId);
        allow delete: if isTeamAdmin(resource.data);
      }

      match /feedPosts/{postId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isTeamMember(request.resource.data) && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isTeamAdmin(resource.data) || request.auth.uid == resource.data.authorId;

        match /comments/{commentId} {
          allow get, list: if isTeamMember(resource.data);
          allow create: if isTeamMember(request.resource.data) && request.resource.data.authorId == request.auth.uid;
          allow update, delete: if isTeamAdmin(resource.data) || request.auth.uid == resource.data.authorId;
        }
      }

      match /events/{eventId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isTeamAdmin(request.resource.data);
        allow update, delete: if isTeamAdmin(resource.data);
      }

      match /games/{gameId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isTeamAdmin(request.resource.data);
        allow update, delete: if isTeamAdmin(resource.data);
      }

      match /alerts/{alertId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isTeamAdmin(request.resource.data);
        allow update, delete: if isTeamAdmin(resource.data);
      }

      match /files/{fileId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isTeamMember(request.resource.data) && request.resource.data.uploadedBy == request.auth.uid;
        allow update, delete: if isTeamAdmin(resource.data) || request.auth.uid == resource.data.uploadedBy;
      }

      match /groupChats/{chatId} {
        allow get, list: if isTeamMember(resource.data);
        allow create: if isTeamMember(request.resource.data);
        allow update, delete: if isTeamAdmin(resource.data);

        match /messages/{messageId} {
          allow get, list: if isTeamMember(resource.data);
          allow create: if isTeamMember(request.resource.data) && request.resource.data.authorId == request.auth.uid;
          allow update: if request.auth.uid == resource.data.authorId;
          allow delete: if isTeamAdmin(resource.data) || request.auth.uid == resource.data.authorId;
        }
      }
    }
  }
}
