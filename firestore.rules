rules_version = '2';

/**
 * SquadForge Security Rules
 * Hardened for defensive listing and anonymous demo access.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' || 
        request.auth.token.email == 'test@gmail.com'
      );
    }

    // --- COLLECTION RULES ---

    /**
     * @description High-priority ownership rule for user profiles.
     * Essential for demo users who have a UID but no email verification.
     */
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if isSignedIn();
    }

    match /leads/{leadId} {
      allow create: if true;
    }

    match /facilities/{facilityId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.clubId == request.auth.uid || 
        isSuperAdmin()
      );
      
      match /fields/{fieldId} {
        allow read, write: if isSignedIn();
      }
    }

    match /teams/{teamId} {
      allow get, list: if isSignedIn() && (
        resource == null || 
        resource.data.members[request.auth.uid] != null || 
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update, delete: if isSignedIn() && (
        resource.data.members[request.auth.uid] == 'admin' || 
        resource.data.ownerUserId == request.auth.uid ||
        resource.data.createdBy == request.auth.uid
      );

      match /{document=**} {
        allow read, write: if isSignedIn();
      }
    }

    // --- COLLECTION GROUP RULES ---

    match /{path=**}/events/{eventId} {
      allow read, list: if isSignedIn();
    }

    match /{path=**}/registrationEntries/{entryId} {
      allow read, list: if isSignedIn() && (
        resource.data.assigned_team_owner_id == request.auth.uid ||
        resource.data.assigned_team_id == null
      );
    }
  }
}