rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'thisearlyseason@gmail.com' || 
        request.auth.token.get('email', '') == 'test@gmail.com'
      );
    }

    function isDemoTeam(tid) {
      // Robust string slice comparison for anonymous guest sessions
      return tid != null && tid.size() >= 5 && tid[0:5] == 'demo_';
    }

    function isTeamMember(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) || 
        isSuperAdmin() ||
        (teamId != null && exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)))
      );
    }

    function isTeamAdmin(teamId) {
      return isSignedIn() && (
        isDemoTeam(teamId) ||
        isSuperAdmin() ||
        (teamId != null && exists(/databases/$(database)/documents/teams/$(teamId)) && (
          get(/databases/$(database)/documents/teams/$(teamId)).data.get('ownerUserId', '') == request.auth.uid ||
          (exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)).data.get('role', '') == 'Admin')
        ))
      );
    }

    // --- COLLECTION GROUP RULES (Must be top-level for static authorization of aggregated queries) ---
    match /{path=**}/events/{eventId} {
      allow read: if isSignedIn();
    }
    
    match /{path=**}/registrationEntries/{entryId} {
      allow read: if isSignedIn();
      allow create: if true; 
      allow update: if isSignedIn();
    }

    // --- GLOBAL COLLECTIONS ---
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if isSignedIn(); 
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isSuperAdmin();
      }
    }

    match /players/{playerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /leagues/{leagueId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
      
      match /registration/config {
        allow read: if true;
        allow write: if isSignedIn();
      }
      
      match /registrationEntries/{entryId} {
        allow list, get: if isSignedIn();
        allow create: if true;
        allow update, delete: if isSignedIn();
      }
      
      match /invites/{inviteId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();

      match /fields/{fieldId} {
        allow list, get: if isSignedIn();
        allow write: if isSignedIn();
      }
    }

    match /plans/{planId} {
      allow get, list: if true;
    }

    match /features/{featureId} {
      allow get, list: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
    }

    // --- TEAM SCOPED HUB ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /volunteers/{oppId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        allow update: if isSignedIn();
      }

      match /fundraising/{fundId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        allow update: if isSignedIn();
      }

      match /equipment/{itemId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /scouting/{reportId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId) || isOwner(memberId);

        match /evaluations/notes {
          allow read, write: if isTeamAdmin(teamId);
        }
      }

      match /groupChats/{chatId} {
        allow list, get, create, update: if isTeamMember(teamId);
        
        match /messages/{messageId} {
          allow read, create, update: if isTeamMember(teamId);
        }
      }
      
      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
        
        match /registrations/{regId} {
          allow list, get: if isSignedIn();
          allow create: if true;
        }
      }

      match /games/{gameId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }
      
      match /drills/{drillId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
      }

      match /alerts/{alertId} {
        // High priority rule for real-time broadcasts
        allow read: if isSignedIn() && (isDemoTeam(teamId) || isSuperAdmin() || exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)));
        allow write: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isTeamMember(teamId);
        allow write: if isTeamAdmin(teamId);
        
        match /comments/{commentId} {
          allow read, create: if isTeamMember(teamId);
          allow delete: if isTeamAdmin(teamId) || resource.data.authorId == request.auth.uid;
        }
      }
    }
  }
}
