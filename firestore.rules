rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- CORE AUTHORIZATION HELPERS ---

    function isSignedIn() {
      return request.auth != null && request.auth.uid != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- INSTITUTIONAL & PERSONAL HIERARCHIES ---
    // We use explicit matches for collections to satisfy Firestore's 'List Proving'
    // for collection-wide queries (listing).

    match /leagues/{leagueId} {
      allow read, write: if isSignedIn();
      
      // Named subcollections for explicit list-proving
      match /registrationEntries/{id} { allow read, write: if isSignedIn(); }
      match /registration/{id} { allow read, write: if isSignedIn(); }
      match /payments/{id} { allow read, write: if isSignedIn(); }
      
      // Fallback for nested data
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /teams/{teamId} {
      allow read, write: if isSignedIn();
      
      // Named subcollections for explicit list-proving
      match /members/{id} { allow read, write: if isSignedIn(); }
      match /events/{id} { allow read, write: if isSignedIn(); }
      match /games/{id} { allow read, write: if isSignedIn(); }
      match /feedPosts/{id} { allow read, write: if isSignedIn(); }
      match /groupChats/{id} { allow read, write: if isSignedIn(); }
      match /files/{id} { allow read, write: if isSignedIn(); }
      match /equipment/{id} { allow read, write: if isSignedIn(); }
      match /incidents/{id} { allow read, write: if isSignedIn(); }
      match /volunteers/{id} { allow read, write: if isSignedIn(); }
      match /fundraising/{id} { allow read, write: if isSignedIn(); }
      
      // Fallback for nested data (e.g. messages, comments)
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /players/{playerId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /facilities/{facilityId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Named subcollections for explicit list-proving
      match /teamMemberships/{id} { allow read, write: if isOwner(userId); }
      match /hiddenChats/{id} { allow read, write: if isOwner(userId); }
      
      match /{allPaths=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- GLOBAL COLLECTIONS & SENTINELS ---

    match /leagues/global/invites/{id} {
      allow read, write: if isSignedIn();
    }

    match /team_memberships/{membershipId} {
      allow read, write: if isSignedIn();
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /features/{featureId} {
      allow read: if true;
    }

    match /subscriptions/{userId} {
      allow read, write: if isOwner(userId);
    }

    // --- COLLECTION GROUP ACCESS ---
    // Required for master intelligence queries in the Club and Family hubs
    
    match /{path=**}/registrationEntries/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/members/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/events/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/files/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/teamMemberships/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/signatures/{id} { allow read, write: if isSignedIn(); }
    match /{path=**}/incidents/{id} { allow read, write: if isSignedIn(); }

    // --- GLOBAL DEFAULT DENY ---
    match /{path=**} {
      allow read, write: if false;
    }
  }
}