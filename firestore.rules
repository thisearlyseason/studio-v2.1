
/**
 * SquadForge Firestore Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a robust, role-based and ownership-based security model.
 * It is designed to handle batch operations, collaborative engagement (polls/likes),
 * and dynamic feature gating.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an application administrator (Super Admin).
     */
    function isAdmin() {
      // Treating specific emails as super-admins for platform management and global config.
      return isSignedIn() && (
        request.auth.token.email == 'thisearlyseason@gmail.com' || 
        request.auth.token.email == 'test@gmail.com'
      );
    }

    /**
     * @description Robust check if the user is an admin of a specific team.
     * Checks both the 'members' map on the team document and legacy 'createdBy' field.
     */
    function isTeamAdmin(teamId) {
      let teamPath = /databases/$(database)/documents/teams/$(teamId);
      let hasTeam = exists(teamPath);
      let teamData = hasTeam ? get(teamPath).data : null;
      
      return isAdmin() || (isSignedIn() && hasTeam && (
        (teamData.members != null && teamData.members[request.auth.uid] == 'Admin') || 
        teamData.createdBy == request.auth.uid || 
        teamData.creatorId == request.auth.uid ||
        teamData.isDemo == true
      ));
    }

    // --- COLLECTION RULES ---

    /**
     * @description Personal user account data.
     */
    match /users/{userId} {
      allow get, list, create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      
      match /teamMemberships/{membershipId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    /**
     * @description Team entities and their nested sub-resources.
     */
    match /teams/{teamId} {
      // Any signed-in user can view teams (for joining) or create a new one.
      allow get, list, create: if isSignedIn();
      allow update, delete: if isTeamAdmin(teamId);

      match /members/{memberId} {
        allow read: if isSignedIn();
        // Critical: Allow create if the user is setting up their own member doc (handles batches)
        // or if they are a team admin.
        allow create: if isSignedIn() && (memberId == request.auth.uid || isTeamAdmin(teamId));
        allow update: if isSignedIn() && (memberId == request.auth.uid || isTeamAdmin(teamId));
        allow delete: if isTeamAdmin(teamId);
      }

      match /events/{eventId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);

        match /registrations/{regId} {
          // Public registrations are open for creation (leads/public links)
          allow create: if true; 
          allow read, delete: if isTeamAdmin(teamId);
        }
      }

      match /games/{gameId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /drills/{drillId} {
        allow read: if isSignedIn();
        allow write: if isTeamAdmin(teamId);
      }

      match /files/{fileId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // Allow deletion if admin or the original uploader.
        allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.uploaderId == request.auth.uid);
      }

      match /alerts/{alertId} {
        allow read: if isSignedIn();
        allow create, delete: if isTeamAdmin(teamId);
      }

      match /feedPosts/{postId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        // Broad update allowed for likes and poll voting increments.
        allow update: if isSignedIn();
        allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.authorId == request.auth.uid);

        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }

      match /groupChats/{chatId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isTeamAdmin(teamId);

        match /messages/{messageId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn();
          // Allow update for poll voting.
          allow update: if isSignedIn();
          allow delete: if isTeamAdmin(teamId) || (resource != null && resource.data.authorId == request.auth.uid);
        }
      }
    }

    /**
     * @description Global application configuration.
     * All users must be able to read these for feature gating to work.
     */
    match /features/{featureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }
  }
}
